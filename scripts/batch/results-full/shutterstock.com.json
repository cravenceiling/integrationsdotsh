    "summary": "Shutterstock exposes one HTTP API and one CLI, both requiring an app-issued client ID/secret for basic auth or an OAuth access token; all requests also require a User-Agent header.",
    "credentials": {
      "shutterstock_app": {
        "type": "app",
        "label": "Shutterstock API application (client ID + client secret)",
        "generateUrl": "https://www.shutterstock.com/account/developers/apps",
        "setup": "Go to [My apps](https://www.shutterstock.com/account/developers/apps) and click **Create new app**. Save the resulting `client ID` and `client secret` (also called the application’s consumer key/secret). Set a callback URL if you plan to use OAuth, and add referrer domains if you need front-end auth. You also need an API subscription; create a free subscription during app creation or use a paid API subscription."
      },
      "shutterstock_basic": {
        "type": "basic",
        "label": "Shutterstock basic auth using client ID + client secret",
        "setup": "Use the application’s `client ID` and `client secret` from [My apps](https://www.shutterstock.com/account/developers/apps). For HTTP basic auth, send those two values as the Basic credentials. The docs note this is sufficient for some endpoints, especially search and media metadata."
      },
      "shutterstock_oauth_token": {
        "type": "bearer",
        "label": "Shutterstock OAuth access token",
        "setup": "Create an application at [My apps](https://www.shutterstock.com/account/developers/apps), then obtain an OAuth token using the Shutterstock OAuth flow described in the authentication docs. Store the resulting access token and send it as the API token for OAuth-authenticated requests. The CLI can also use this token via `SHUTTERSTOCK_API_TOKEN`."
      },
      "shutterstock_cli_env": {
        "type": "compound",
        "label": "Shutterstock CLI auth environment variables",
        "setup": "Install the CLI with `pip install shutterstock-cli`, then authenticate by providing either `SHUTTERSTOCK_KEY` + `SHUTTERSTOCK_SECRET` for basic auth or `SHUTTERSTOCK_API_TOKEN` for OAuth. The CLI does not mint OAuth tokens itself; it consumes the token you obtained from Shutterstock’s OAuth flow."
      }
    },
