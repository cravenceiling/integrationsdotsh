      "sg_access_token": {
        "type": "api_key",
        "label": "Sourcegraph access token",
        "generateUrl": "https://sourcegraph.com/docs/cli/how-tos/creating-an-access-token",
        "setup": "Create a personal or service-account access token in your Sourcegraph instance. The docs reference **Settings > Access tokens** for users and service-account **Access tokens** for service accounts; start from [creating an access token](https://sourcegraph.com/docs/cli/how-tos/creating-an-access-token) or [service accounts](https://sourcegraph.com/docs/admin/service-accounts). Use the `mcp` scope for MCP-only access when desired.",
