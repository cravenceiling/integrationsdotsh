    "summary": "LanceDB exposes a documented Enterprise REST API plus official SDK clients (Python, TypeScript, Rust, Java); authentication is via Enterprise API keys, and some SDKs also support OAuth client credentials or Azure managed identity.",
    "description": "LanceDB is a multimodal lakehouse for AI data workflows, combining vectors, metadata, and source data in a unified table format. It offers an embedded open-source library for local/object-storage use and an Enterprise deployment option for remote, managed or private-cloud access.",
    "credentials": {
      "enterprise_api_key": {
        "type": "api_key",
        "label": "LanceDB Enterprise API key",
        "generateUrl": "https://docs.lancedb.com/api-reference/rest",
        "setup": "Get the API key and Enterprise endpoint from your LanceDB administrator or the LanceDB team that provisioned your deployment, as described in the [REST API authentication docs](https://docs.lancedb.com/api-reference/rest) and [Enterprise authentication docs](https://docs.lancedb.com/enterprise/authentication). Store the key securely and pass it as `x-api-key` for REST calls, or as `api_key` when connecting SDK clients to a `db://` URI. If your deployment uses a private endpoint or `host_override`, you may also need the database name for the `x-lancedb-database` header."
      },
      "enterprise_oauth_client": {
        "type": "oauth2_cc",
        "label": "LanceDB Enterprise OAuth client credentials",
        "generateUrl": "https://docs.lancedb.com/enterprise/authentication",
        "setup": "Register an OAuth/OIDC application with your identity provider for your LanceDB Enterprise deployment, then configure the client with the issuer URL, client ID, client secret, and scopes as shown in the [Enterprise authentication docs](https://docs.lancedb.com/enterprise/authentication). Use the Client Credentials flow for service-to-service access. LanceDB SDKs obtain and refresh bearer tokens from your identity provider; you provide the `issuer_url`, `client_id`, `client_secret`, and `scopes` in the SDK config."
      },
      "enterprise_managed_identity": {
        "type": "oauth2",
        "label": "Azure managed identity for LanceDB Enterprise",
        "generateUrl": "https://docs.lancedb.com/enterprise/authentication",
        "setup": "For Azure-hosted workloads, configure a managed identity that is allowed to get tokens for your LanceDB Enterprise deployment, then supply the issuer URL, client ID, scopes, and optionally `managed_identity_client_id` for user-assigned identities, as documented in [Enterprise authentication](https://docs.lancedb.com/enterprise/authentication). LanceDB SDKs fetch tokens from Azure IMDS automatically; no client secret is stored on the client."
      }
    },
