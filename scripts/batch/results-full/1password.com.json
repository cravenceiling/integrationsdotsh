      "op_service_account_token": {
        "type": "bearer",
        "label": "1Password service account token",
        "generateUrl": "https://www.1password.dev/service-accounts/get-started",
        "setup": "Create it from [1Password Service Accounts](https://www.1password.dev/service-accounts/get-started) on 1Password.com or with `op service-account create`. The wizard shows the token only once; save it immediately in 1Password. Use the token as `OP_SERVICE_ACCOUNT_TOKEN` (or equivalent env var) for CLI/SDK access. Treat it like a password; it is tied to the vaults and Environments you selected.",
        "acquisition": "manual"
      },
      "op_connect_token": {
        "type": "bearer",
        "label": "1Password Connect access token",
        "generateUrl": "https://www.1password.dev/connect/get-started",
        "setup": "Create a Connect server workflow in [1Password Connect](https://www.1password.dev/connect/get-started) or with `op connect server create`. The setup generates a `1password-credentials.json` file plus an access token for apps and services to call the Connect REST API. Save the token securely; you can issue additional tokens later from the Connect management flow.",
        "acquisition": "manual"
      },
      "op_events_bearer_token": {
        "type": "bearer",
        "label": "1Password Events API bearer token",
        "generateUrl": "https://www.1password.dev/events-api/get-started",
        "setup": "Create an Events Reporting integration in your 1Password Business account, then issue a bearer token from the integration wizard. Choose the events it can access, and save the token in 1Password because the wizard only shows it once. Use it as the `Authorization: Bearer ...` token when calling the Events API.",
        "acquisition": "manual"
      },
      "op_partner_bearer_token": {
        "type": "bearer",
        "label": "1Password Partnership API bearer token",
        "generateUrl": "https://www.1password.dev/partnership-api/reference",
        "setup": "Register as a 1Password partner through the partner program to obtain authorization for the Partnership API. Registered partners are granted bearer tokens for the billing servers; request access via the partner program or your 1Password contact. Store the token securely and send it as the API bearer credential.",
