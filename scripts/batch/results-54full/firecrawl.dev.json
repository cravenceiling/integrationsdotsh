    "summary": "Firecrawl exposes a documented HTTP API at https://api.firecrawl.dev/v2, a Node-based `firecrawl` CLI, and an MCP server documented for agent clients; authentication centers on Firecrawl API keys, with WorkOS ID-JAG supported as an agent-side registration flow to mint those keys.",
    "description": "Firecrawl is a web data platform for AI agents and applications that can search the web, scrape pages, crawl sites, map URLs, parse documents, and interact with pages through managed browser automation. It is offered as a hosted API service with accompanying CLI and MCP tooling.",
    "credentials": {
      "fc_api_key": {
        "type": "bearer",
        "label": "Firecrawl API key",
        "generateUrl": "https://www.firecrawl.dev/signin",
        "setup": "Sign up or sign in at [Firecrawl](https://www.firecrawl.dev/signin). Then create or view your API key in the dashboard, or run the CLI login flow from [Skills + CLI](https://docs.firecrawl.dev/sdks/cli) using `firecrawl login --browser` or `firecrawl login --api-key ...`. The issued key has the `fc-...` format and is sent as `Authorization: Bearer <token>`.",
        "acquisition": "manual"
      },
      "workos_id_jag": {
        "type": "jwt",
        "label": "WorkOS ID-JAG identity assertion",
        "generateUrl": "https://www.firecrawl.dev/auth.md",
        "setup": "Use this only if your agent platform can mint WorkOS ID-JAG assertions for Firecrawl. Follow [auth.md](https://www.firecrawl.dev/auth.md): discover metadata from [Protected Resource Metadata](https://www.firecrawl.dev/.well-known/oauth-protected-resource) and [Authorization Server Metadata](https://www.firecrawl.dev/.well-known/oauth-authorization-server), then mint an ID-JAG JWT with audience `https://api.firecrawl.dev/` and the required verified-email claims, and submit it to `POST https://www.firecrawl.dev/agent/auth` to receive a Firecrawl API key. Most users should use the dashboard or CLI path instead, per [Build with AI](https://docs.firecrawl.dev/ai-onboarding).",
        "acquisition": "manual"
      }
    },
