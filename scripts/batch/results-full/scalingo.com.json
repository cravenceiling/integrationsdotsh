    "summary": "Scalingo exposes a v1 REST API, a separate authentication API, a database API, an addon-provider API, and a CLI; all programmatic surfaces are authenticated, mostly via Bearer tokens exchanged from a Scalingo API token, while the addon-provider API uses HTTP Basic.",
    "credentials": {
      "scalingo_api_token": {
        "type": "api_key",
        "label": "Scalingo API token",
        "generateUrl": "https://dashboard.scalingo.com/account/tokens",
        "setup": "Go to the [API tokens page](https://dashboard.scalingo.com/account/tokens) in your Scalingo dashboard and create a new token. If you prefer CLI-assisted login, Scalingo’s docs note that CLI login may depend on how your account was created, but the token itself is minted on the dashboard or via the auth API. Keep the raw token secret; it is exchanged for short-lived Bearer tokens before calling the main API.",
        "acquisition": "manual"
      },
      "scalingo_bearer_token": {
        "type": "bearer",
        "label": "Scalingo Bearer token",
        "generateUrl": "https://auth.scalingo.com/v1/tokens/exchange",
        "setup": "This is a short-lived token obtained by exchanging a Scalingo API token against the authentication API. First mint an API token in the [dashboard](https://dashboard.scalingo.com/account/tokens) or via the auth API, then call `POST https://auth.scalingo.com/v1/tokens/exchange` with HTTP Basic auth using `:<your token>`. The returned `token` value is the Bearer token used on the main API.",
        "acquisition": "manual"
      },
      "scalingo_user_password": {
        "type": "basic",
        "label": "Scalingo account username and password",
        "generateUrl": "https://auth.scalingo.com/users/sign_in",
        "setup": "Use your Scalingo account credentials on the authentication API when creating or exchanging tokens. If you sign in with GitHub on the web dashboard, the CLI docs say you may need to use the dashboard flow to obtain an API token instead of relying on a password-based login. The auth endpoints accept HTTP Basic auth with your `username:password` pair.",
        "acquisition": "manual"
      }
