        "type": "compound",
        "label": "Vonage CLI authenticated configuration",
        "generateUrl": "https://developer.vonage.com/en/getting-started/tools/cli",
        "setup": "Install the Vonage CLI with `npm install -g @vonage/cli` or `yarn global add @vonage/cli`, then run `vonage auth set` and provide your `--api-key`, `--api-secret`, `--app-id`, and `--private-key`. The CLI stores these in `.vonagerc` or `~/.vonage/config.json` and uses them for subsequent commands.",
        "acquisition": "manual"
      }
