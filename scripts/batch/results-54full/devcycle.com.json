    "summary": "DevCycle exposes two HTTP APIs (Management and Bucketing), a hosted MCP server, and a `dvc` CLI; all require DevCycle-issued credentials.",
    "description": "DevCycle is a feature flag and experimentation platform built around OpenFeature. It lets teams manage flags, targeting, variables, and evaluations across applications and environments.",
    "credentials": {
      "management_client_credentials": {
        "type": "oauth2_cc",
        "label": "Management API OAuth client credentials",
        "generateUrl": "https://app.devcycle.com/r/settings",
        "setup": "In the DevCycle dashboard, open [Settings](https://app.devcycle.com/r/settings) to get your `client_id` and `client_secret`. Exchange them at `https://auth.devcycle.com/oauth/token` with `grant_type=client_credentials` and `audience=https://api.devcycle.com/` to obtain a bearer access token for the Management API, as shown in the [Management API docs](https://docs.devcycle.com/management-api/)."
      },
      "management_refresh_token": {
        "type": "oauth2",
        "label": "Enterprise Management API refresh token",
        "generateUrl": "https://app.devcycle.com/r/settings",
        "setup": "For Enterprise orgs with strict roles and permissions enabled, obtain the DevCycle API `client_id` from [Settings](https://app.devcycle.com/r/settings), then use your DevCycle-issued refresh token with `grant_type=refresh_token` at `https://auth.devcycle.com/oauth/token` as documented in the [Management API docs](https://docs.devcycle.com/management-api/). The refresh token is organization/user-specific and is used to mint the bearer token accepted by the API."
      },
      "bucketing_sdk_key": {
        "type": "api_key",
        "label": "Environment SDK key",
        "generateUrl": "https://app.devcycle.com/",
        "setup": "In the DevCycle dashboard, open your environment's SDK Keys section (the CLI guides link to [SDK Keys](https://docs.devcycle.com/cli-guides/keys)) and copy the environment `sdkKey`. The [Bucketing API docs](https://docs.devcycle.com/bucketing-api/) state requests can send this key either in the `Authorization` header or as the `sdkKey` query parameter."
      },
      "cli_access_token": {
        "type": "bearer",
        "label": "CLI login access token",
        "setup": "Install the CLI from [CLI docs](https://docs.devcycle.com/cli/) and run `dvc login sso` (or `dvc repo init`). The CLI opens the DevCycle universal login in a browser, stores an access token valid for 24 hours, and can refresh it with `dvc login again`, per the [CLI authentication docs](https://docs.devcycle.com/cli/)."
      },
      "cli_client_credentials": {
        "type": "compound",
        "label": "CLI client ID and client secret",
        "generateUrl": "https://app.devcycle.com/r/settings",
        "setup": "In the DevCycle dashboard, open [Settings](https://app.devcycle.com/r/settings) to get your DevCycle `client_id` and `client_secret`. Configure them for the CLI in the auth file described in the [CLI docs](https://docs.devcycle.com/cli/) under \"Using Client Credentials\", with YAML fields `clientCredentials.client_id` and `clientCredentials.client_secret`."
      }
    },
