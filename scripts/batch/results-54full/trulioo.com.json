      "napi_basic": {
        "type": "basic",
        "label": "Normalized API username and password",
        "generateUrl": "https://developer.trulioo.com/reference/keys-and-authentication-2.md",
        "setup": "Use the username and password for your Trulioo Normalized API account. Trulioo says this account is needed to access NAPI, and if you don't have one you should contact [Trulioo Support](mailto:support@trulioo.com). Send them as HTTP Basic auth: `Authorization: Basic base64(username:password)`.",
        "acquisition": "manual"
      },
      "napi_mtls_cert": {
        "type": "compound",
        "label": "Trulioo-issued mTLS client certificate",
        "generateUrl": "https://developer.trulioo.com/reference/connecting-to-trulioos-api-using-mutual-tls.md",
        "setup": "To use mTLS, first have a Trulioo normalized API user account and a \"Manage mTLS\" Customer Portal user account. Generate a private key and CSR, then log in to the Customer Portal with your Manage mTLS credentials, upload the CSR, and download the Trulioo-issued client certificate as described in [Connecting to Trulioo's API using Mutual TLS - v1](https://developer.trulioo.com/reference/connecting-to-trulioos-api-using-mutual-tls.md). Install that certificate and its private key on the server making API calls. If you lack either account, contact [Trulioo Support](mailto:support@trulioo.com).",
        "acquisition": "manual"
      },
      "oauth_client": {
        "type": "oauth2_cc",
        "label": "OAuth client ID and client secret",
        "generateUrl": "https://developer.trulioo.com/reference/workflow-studio-api.md",
        "setup": "Obtain a Trulioo Client ID and Client Secret from your Implementation Specialist. The Workflow Studio API docs say these are required for authentication and are not the same credentials as workflow export step credentials. Use them to obtain an access token from `http://auth-api.trulioo.com/connect/token` as described in [Authentication](https://developer.trulioo.com/reference/authentication-recipe) and [Workflow Studio (API)](https://developer.trulioo.com/reference/workflow-studio-api.md).",
        "acquisition": "manual"
      },
      "docv_license": {
        "type": "api_key",
        "label": "KYC Document / Customer API license key",
        "generateUrl": "https://docs.verification.trulioo.com/sdk/demo-license/index.html",
        "setup": "Use your Trulioo KYC Document Verification license key for the Customer API authorization call. The Customer API docs say you pass the license in the authorization header to `/authorize` to mint transaction access tokens. Trulioo provides a [Demo License](https://docs.verification.trulioo.com/sdk/demo-license/index.html) page in the KYC Docs developer docs, and production credentials are obtained through your Trulioo account/onboarding.",
        "acquisition": "manual"
      },
      "docv_access_token": {
        "type": "bearer",
        "label": "Customer API access token",
        "generateUrl": "https://docs.verification.trulioo.com/api/customer/3.0/index.html",
        "setup": "For Customer API v2.5, call `/authorize/customer` with your license key in the authorization header to receive an `accessToken`; for v3.0, obtain an OAuth2 client-credentials access token as described in [KYC Document API (3.0)](https://docs.verification.trulioo.com/api/customer/3.0/index.html) and [Authentication](https://developer.trulioo.com/reference/authentication-recipe). Use the returned access token in the `Authorization` header for subsequent transaction endpoints.",
        "acquisition": "manual"
