---
// The domain page, markup + head — rendered two ways with zero drift:
//  - prerendered at build ([domain].astro) with the catalog seed only; the
//    island mounts idle and offers "Map integration surface".
//  - SSR'd in the worker (ssr/[domain].astro) when a stored discovery exists
//    in KV; `initialData` bakes the discovered map into the HTML so the page
//    arrives already in the "done" state — no idle-button flash.
import Base from "~/layouts/Base.astro";
import Breadcrumb from "~/components/Breadcrumb.astro";
import Surfaces from "~/components/Surfaces.tsx";
import type { CatalogSection, DiscoverData } from "~/components/Surfaces.tsx";
import { faviconUrl } from "~/lib/favicon.ts";
import { KIND_ORDER, SECTION_LABEL, SHORT_LABEL } from "~/lib/domain-labels.ts";
import type { Kind } from "~/lib/types.ts";
import "~/styles/discovery.css";

interface Props {
  domain: string;
  catalog: CatalogSection[];
  /** Stored discovery to bake in (SSR path). */
  initialData?: DiscoverData | null;
}

const { domain, catalog, initialData = null } = Astro.props;

// Header line: counts and kinds from the catalog; a discovered-only domain
// (no catalog records, e.g. mapped live from the 404 page) falls back to the
// discovery's surfaces.
const catalogKinds = KIND_ORDER.filter((k) => catalog.some((s) => s.kind === k && s.items.length));
const total = catalog.reduce((n, s) => n + s.items.length, 0);
const discoveredKinds = KIND_ORDER.filter((k) =>
  (initialData?.surfaces ?? []).some((s) => (s.type === "http" || s.type === "rest" ? "openapi" : s.type) === k),
);
const kinds = catalogKinds.length ? catalogKinds : discoveredKinds;
const count = total || (initialData?.surfaces?.length ?? 0);

const icon = faviconUrl(domain);
const letter = (domain[0] ?? "?").toUpperCase();

const formatList = kinds.map((k) => SECTION_LABEL[k as Kind].replace(" · ", "/")).join(", ");
const title = `${domain} — integrations`;
const description = `${count} integration${count === 1 ? "" : "s"} for ${domain} across ${formatList} — readable by you and your agent.`;
---

<Base title={title} description={description} path={`/${domain}/`}>
  <div class="container">
    <article>
      <Breadcrumb
        segments={[
          { label: "registry", href: "/" },
          { label: domain },
        ]}
      />

      <header class="head">
        <div class="favicon">
          <span class="fav-letter">{letter}</span>
          {icon && <img src={icon} width="22" height="22" alt="" loading="lazy" onerror="this.remove()" />}
        </div>
        <div class="head-body">
          <h1>{domain}</h1>
          <p class="meta">
            {count} integration{count === 1 ? "" : "s"}
            {" · "}{kinds.map((k) => SHORT_LABEL[k as Kind]).join(" · ")}
          </p>
        </div>
      </header>

      <Surfaces domain={domain} catalog={catalog} initialData={initialData} client:visible />
    </article>
  </div>
</Base>
