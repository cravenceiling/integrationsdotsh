    "summary": "Webflow exposes the Data API, MCP server, and Webflow CLI; Data API auth supports OAuth app tokens, site API tokens, and enterprise workspace API tokens, while the MCP server and CLI use Webflow OAuth/login flows or workspace tokens.",
    "credentials": {
      "wf_oauth_app": {
        "type": "oauth2",
        "label": "Webflow App OAuth client",
        "generateUrl": "https://developers.webflow.com/data/docs/register-an-app.md",
        "setup": "Create a Webflow App in your Workspace’s **Apps & Integrations → App Development** section. Choose the **Data Client** building block, add your HTTPS redirect URI, and enable the scopes your integration needs. Webflow shows the `Client ID` and `Client Secret` after registration. Use the client credentials to run the Authorization Code flow and obtain an access token for the user/workspace.",
        "acquisition": "manual"
      },
      "wf_site_token": {
        "type": "bearer",
        "label": "Webflow Site API token",
        "generateUrl": "https://developers.webflow.com/data/v2.0.0/reference/authentication/site-token.md",
        "setup": "In the target site’s **Site settings → Apps & integrations → API access**, click **Generate API token**, name it, choose the needed scopes, and copy the token. Send it as `Authorization: Bearer <token>` when calling the Data API. Site admins create these tokens; they are per-site and can be revoked from the same page.",
        "acquisition": "manual"
      },
      "wf_workspace_token": {
        "type": "bearer",
        "label": "Webflow Workspace API token",
        "generateUrl": "https://developers.webflow.com/data/v2.0.0/reference/authentication/workspace-token.md",
        "setup": "In an Enterprise workspace, go to **Apps & integrations → Manage → Workspace API access**, click **Generate API token**, name it, choose the needed permissions, and copy the token. Send it as `Authorization: Bearer <token>` for workspace-level Data API requests and as `--api-token <token>` or `WEBFLOW_API_TOKEN` for the CLI. Workspace admins create and revoke these tokens.",
        "acquisition": "manual"
      },
      "wf_cli_login": {
        "type": "oauth2",
        "label": "Webflow CLI workspace login",
        "generateUrl": "https://developers.webflow.com/cli/authentication.md",
        "setup": "Run `webflow auth login`. The CLI opens a browser, you pick a workspace, and it writes a fresh `WEBFLOW_API_TOKEN` into your project’s `.env` file. This is the easiest way to authenticate the CLI for interactive use.",
        "acquisition": "manual"
      }
