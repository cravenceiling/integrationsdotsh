---
// The one shell every page renders through — prerendered catalog pages and
// worker-SSR'd discovery pages alike, so there is nothing to drift.
import "~/styles/global.css";
import Nav from "~/components/Nav.astro";
import Footer from "~/components/Footer.astro";
import { ANALYTICS_JS } from "~/lib/analytics.ts";

interface Props {
  title: string;
  description?: string;
  /** Canonical path, e.g. "/todoist/". */
  path?: string;
  /** Absolute-path OG image URL, e.g. "/og/todoist.com.png". */
  ogImagePath?: string;
  jsonLd?: object | object[];
}
const {
  title,
  description = "Services your agent can reach — official APIs, GraphQL endpoints, and MCP servers, with structured credential facts.",
  path,
  ogImagePath,
  jsonLd,
} = Astro.props;
const canonical = path ? new URL(path, Astro.site).href : undefined;
const ogImage = ogImagePath ? new URL(ogImagePath, Astro.site).href : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="integrations.sh" />
    {canonical && <meta property="og:url" content={canonical} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/svg+xml" href="/favicon-light.svg" media="(prefers-color-scheme: dark)" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preload" href="/fonts/geist-400.woff" as="font" type="font/woff" crossorigin />
    <link rel="preload" href="/fonts/geist-mono-400.woff" as="font" type="font/woff" crossorigin />
    <style is:inline>
      @font-face {
        font-family: "Geist";
        src: url("/fonts/geist-400.woff") format("woff");
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: "Geist";
        src: url("/fonts/geist-500.woff") format("woff");
        font-weight: 500;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: "Geist";
        src: url("/fonts/geist-600.woff") format("woff");
        font-weight: 600;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: "Geist Mono";
        src: url("/fonts/geist-mono-400.woff") format("woff");
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: "Geist Mono";
        src: url("/fonts/geist-mono-500.woff") format("woff");
        font-weight: 500;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: "Geist Mono";
        src: url("/fonts/geist-mono-600.woff") format("woff");
        font-weight: 600;
        font-style: normal;
        font-display: swap;
      }
    </style>
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <script is:inline set:html={ANALYTICS_JS} />
  </head>
  <body>
    <div class="frame-guides"></div>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
