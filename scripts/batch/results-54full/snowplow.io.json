    "summary": "Snowplow exposes a documented Console REST API, a Snowplow CLI, a local stdio MCP server bundled with the CLI, and a remote HTTP MCP server tied to Snowplow Console authentication.",
    "description": "Snowplow provides customer data infrastructure for collecting, validating, enriching, and delivering event-level behavioral data to warehouses, lakes, streams, and downstream applications. It also includes Event Studio and AI-oriented tooling for managing tracking plans, schemas, and related resources.",
    "credentials": {
      "console_api_key_pair": {
        "type": "compound",
        "label": "Snowplow Console API key ID + API key secret",
        "generateUrl": "https://console.snowplowanalytics.com/credentials",
        "setup": "In [Snowplow Console](https://console.snowplowanalytics.com/), go to **Settings** → **Manage organization** → **API keys for managing Snowplow** (or the [credentials section](https://console.snowplowanalytics.com/credentials)). Create an API key and securely save both the `API key ID` and the `API key` secret. The docs state this pair is used together like a username/password combination.",
        "acquisition": "manual"
      },
      "console_access_token": {
        "type": "jwt",
        "label": "Snowplow Console access token",
        "generateUrl": "https://console.snowplowanalytics.com/api/msc/v1/docs/index.html?url=/api/msc/v1/docs/docs.yaml",
        "setup": "First create a [Snowplow Console API key](https://docs.snowplow.io/docs/account-management/). Then exchange the `API key ID` and `API key` at `GET https://console.snowplowanalytics.com/api/msc/v1/organizations/<ORGANIZATION_ID>/credentials/v3/token` using headers `X-API-Key-ID` and `X-API-Key`. The response returns `{\"accessToken\":\"<JWT>\"}`; use that JWT as `Authorization: Bearer <JWT>`. The token is temporary and the docs say it is valid for 24 hours.",
        "acquisition": "manual"
      },
      "console_oauth_login": {
        "type": "oauth2",
        "label": "Snowplow Console OAuth login",
        "generateUrl": "https://console.snowplowanalytics.com/",
        "setup": "For the remote MCP server, sign in to [Snowplow Console](https://console.snowplowanalytics.com/) when your MCP client opens the browser during first use. The MCP docs say the server authenticates through your existing Snowplow Console login via OAuth. For Claude.ai custom connectors, the docs show the MCP URL `https://console.snowplowanalytics.com/api/agent/mcp` and OAuth client ID `NxCcdyu13Cr4umnIYw70evvUyRXRvyWf`; Claude.ai redirects you to Snowplow login to authorize access.",
        "acquisition": "manual"
      }
