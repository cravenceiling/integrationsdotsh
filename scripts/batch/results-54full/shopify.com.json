    "summary": "Shopify exposes Admin REST and GraphQL APIs, Storefront, Partner, Customer Account, and Payments GraphQL APIs, plus an MCP endpoint and the `shopify` CLI; auth is mainly via `X-Shopify-Access-Token` app/store or partner tokens, Storefront public/private tokens, Customer Account OAuth, CLI login, while the recorded MCP supports none or OAuth.",
    "credentials": {
      "shopify_admin_token": {
        "type": "bearer",
        "label": "Shopify app/store access token",
        "generateUrl": "https://shopify.dev/docs/apps/build/authentication-authorization",
        "setup": "Create an app in the [Dev Dashboard](https://shopify.dev/docs/apps/build/dev-dashboard) or scaffold one with [Shopify CLI](https://shopify.dev/docs/apps/build/scaffold-app). Install it on a store to obtain an access token using Shopify-managed installation/token exchange, the [authorization code grant](https://shopify.dev/docs/apps/build/authentication-authorization/access-tokens/authorization-code-grant), or for organization-owned stores the [client credentials grant](https://shopify.dev/docs/apps/build/authentication-authorization/access-tokens/client-credentials-grant). Existing admin-created custom apps can also generate tokens from the Shopify admin via [Generate access tokens for custom apps](https://shopify.dev/docs/apps/build/authentication-authorization/access-tokens/generate-app-access-tokens-admin). Use the resulting token in `X-Shopify-Access-Token`.",
        "acquisition": "manual"
      },
      "shopify_partner_token": {
        "type": "bearer",
        "label": "Partner API client access token",
        "generateUrl": "https://shopify.dev/docs/api/partner/latest#create-a-partner-api-client",
        "setup": "In the [Partners Dashboard](https://partners.shopify.com/), go to **Settings** → **Partner API clients** and create a Partner API client for your organization as described in [Create a Partner API client](https://shopify.dev/docs/api/partner/latest#create-a-partner-api-client). Copy the client access token and your organization ID from the Partners Dashboard URL. Send the token in `X-Shopify-Access-Token` when calling the Partner API.",
        "acquisition": "manual"
      },
      "shopify_storefront_public_token": {
        "type": "api_key",
        "label": "Storefront public access token",
        "generateUrl": "https://shopify.dev/docs/api/usage/authentication#getting-started-with-public-access",
        "setup": "Create a storefront access token either by calling the GraphQL Admin API mutation [`storefrontAccessTokenCreate`](https://shopify.dev/docs/api/admin-graphql/latest/mutations/storefrontAccessTokenCreate) or from a custom app / Headless channel as described in [Shopify API authentication](https://shopify.dev/docs/api/usage/authentication) and [Getting started with the Storefront API](https://shopify.dev/docs/storefronts/headless/building-with-the-storefront-api/getting-started). Use the token in the `X-Shopify-Storefront-Access-Token` header for public Storefront API access.",
        "acquisition": "manual"
      },
      "shopify_storefront_private_token": {
        "type": "api_key",
        "label": "Storefront private access token",
        "generateUrl": "https://shopify.dev/docs/storefronts/headless/building-with-the-storefront-api/getting-started",
        "setup": "Install the [Headless channel](https://apps.shopify.com/headless) on a Shopify store and click **Create storefront** as described in [Getting started with the Storefront API](https://shopify.dev/docs/storefronts/headless/building-with-the-storefront-api/getting-started). Shopify generates public and private Storefront API access tokens for that storefront. Use the private token from a server or other private context.",
        "acquisition": "manual"
      },
      "shopify_customer_account_app": {
        "type": "oauth2",
        "label": "Customer Account API app client",
        "generateUrl": "https://shopify.dev/docs/api/customer/latest",
        "setup": "Configure a Customer Account API client for the storefront/app in Shopify as described in the [Customer Account API reference](https://shopify.dev/docs/api/customer/latest) and the customer account settings referenced there. Use the app's `client_id` in the OAuth flow discovered from the shop's `/.well-known/openid-configuration`, then exchange the authorization code for a customer-scoped access token. The resulting bearer token is used to call the Customer Account API.",
        "acquisition": "manual"
      },
      "shopify_cli_login": {
        "type": "oauth2",
        "label": "Shopify CLI logged-in session",
        "generateUrl": "https://shopify.dev/docs/api/shopify-cli",
        "setup": "Install the CLI with `npm install -g @shopify/cli@latest` (or another supported package manager) from the [Shopify CLI docs](https://shopify.dev/docs/api/shopify-cli), then run `shopify auth login` to sign in and let the CLI store the session it uses for commands.",
        "acquisition": "manual"
      }
    },
