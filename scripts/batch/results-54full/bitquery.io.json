      "bitquery_access_token": {
        "type": "bearer",
        "label": "Bitquery access token",
        "generateUrl": "https://account.bitquery.io/user/api_v2/access_tokens",
        "setup": "Sign in at [Bitquery Account](https://account.bitquery.io/), open **Authorization** → **Applications** to create an application, then open **Authorization** → **Tokens** or the app's **Tokens** page to generate and copy an access token. The docs also note you can sign in to the [GraphQL IDE](https://ide.bitquery.io/) and a token is generated automatically there, but for stable app use Bitquery recommends copying a token from the account token page. Send it as `Authorization: Bearer <access_token>` for HTTP calls, or as the `token` query parameter for the WebSocket endpoint.",
        "acquisition": "manual"
      },
      "bitquery_oauth_app": {
        "type": "oauth2_cc",
        "label": "Bitquery OAuth application client credentials",
        "generateUrl": "https://account.bitquery.io/user/api_v2/applications",
        "setup": "Sign in at [Bitquery Account](https://account.bitquery.io/), open **Authorization** → **Applications**, click **+ New Application**, and create an app. Use that app's client ID and client secret to mint an API token from `https://oauth2.bitquery.io/oauth2/token` with `grant_type=client_credentials` and `scope=api`, as shown in [How to Generate a Token](https://docs.bitquery.io/docs/authorisation/how-to-generate/). This is the programmatic path Bitquery documents for obtaining access tokens.",
        "acquisition": "manual"
      }
