---
// Top nav: wordmark + GitHub star badge. The server-rendered count is the
// baked build value (GitHub fetch/file cache/CI seed, or /disc/meta.json for
// worker SSR) so it paints immediately. A tiny client script then asks
// /api/stars.json for the edge-cached runtime value and updates only the text.
import { REPO_URL, getStars } from "~/lib/github.ts";
import { formatStars } from "~/lib/format.ts";

const stars = await getStars(Astro.locals.runtime?.env);
---

<nav class="site">
  <div class="container">
    <a class="wordmark" href="/">integrations.sh</a>
    <a class="ghstar" href={REPO_URL} target="_blank" rel="noopener">
      <svg class="ghstar-ico" width="13" height="13" viewBox="0 0 16 16" aria-hidden="true">
        <path
          fill="#e3b341"
          d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25z"
        ></path>
      </svg>
      <span>star on github</span>
      {stars != null && <span class="ghstar-n">{formatStars(stars)}</span>}
    </a>
  </div>
</nav>

<script>
  import { formatStars } from "~/lib/format.ts";

  async function updateGitHubStars() {
    try {
      const res = await fetch("/api/stars.json");
      if (!res.ok) return;
      const data = (await res.json()) as { stars?: unknown };
      if (typeof data.stars !== "number") return;

      const link = document.querySelector<HTMLAnchorElement>(".ghstar");
      if (!link) return;
      let count = link.querySelector<HTMLSpanElement>(".ghstar-n");
      if (!count) {
        count = document.createElement("span");
        count.className = "ghstar-n";
        link.append(count);
      }
      count.textContent = formatStars(data.stars);
    } catch {
      // The baked server value is already visible.
    }
  }

  updateGitHubStars();
</script>
