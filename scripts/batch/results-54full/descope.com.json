        "acquisition": "manual"
      },
      "management_key": {
        "type": "bearer",
        "label": "Descope Management Key",
        "generateUrl": "https://app.descope.com/settings/company/managementkeys",
        "setup": "In the Descope Console, go to [Company Settings → Management Keys](https://app.descope.com/settings/company/managementkeys) and generate a management key for your project. The REST docs say management endpoints use a management key, and the CLI docs require setting it in `DESCOPE_MANAGEMENT_KEY`.",
        "acquisition": "manual"
      },
      "access_key": {
        "type": "bearer",
        "label": "Descope Access Key",
        "generateUrl": "https://app.descope.com/accesskeys",
        "setup": "Create an access key in the Descope Console from the [Access Keys page](https://app.descope.com/accesskeys), or via the `descope access-key create` command documented in [descope CLI](https://docs.descope.com/cli/descope). Descope's API docs say management endpoints may use an access key.",
        "acquisition": "manual"
      },
      "refresh_jwt_pair": {
        "type": "compound",
        "label": "Project ID plus Refresh JWT for user-scoped API calls",
        "setup": "Obtain a user's `refresh JWT` by completing a Descope authentication flow such as the OTP flow described in [One-Time-Password APIs](https://docs.descope.com/api/otp). For user-scoped endpoints, Descope documents the header format as `Authorization: Bearer <ProjectID>:<RefreshJWT>`, so this credential is the combination of your project identifier and the user's refresh token.",
        "acquisition": "manual"
      },
      "descope_account": {
        "type": "oauth2",
        "label": "Descope account sign-in for the hosted Descope MCP server",
        "setup": "Connect to the hosted MCP endpoint at [Descope MCP Server docs](https://docs.descope.com/mcp/mcp-server). MCP clients such as Cursor, Claude Desktop, Codex, Windsurf, and ChatGPT are instructed to add `https://mcp.descope.com` and then \"Sign in with your Descope account when prompted.\" The OAuth details are discovered from the server during connection.",
        "acquisition": "manual"
