    "summary": "Trigger.dev exposes a REST Management API, a separate Realtime HTTP API, an MCP server launched via `npx trigger.dev@latest mcp`, and an npm-distributed CLI.",
    "description": "Trigger.dev is an open source platform for durable background jobs, AI agents, and long-running workflows written in TypeScript. It can be used via Trigger.dev Cloud or self-hosted, and includes task execution, realtime updates, and observability features.",
    "credentials": {
      "trigger_secret_key": {
        "type": "api_key",
        "label": "Trigger.dev Secret API key",
        "generateUrl": "https://cloud.trigger.dev",
        "setup": "Sign in to [Trigger.dev Cloud](https://cloud.trigger.dev), open your project, then go to the API Keys page in the dashboard to copy the environment-specific secret key (`tr_dev_…`, `tr_prod_…`, etc.). Use it server-side only. For preview branches, also copy the preview branch value and set `TRIGGER_PREVIEW_BRANCH` as documented on [API keys](https://trigger.dev/docs/apikeys)."
      },
      "trigger_pat": {
        "type": "bearer",
        "label": "Trigger.dev personal access token",
        "generateUrl": "https://cloud.trigger.dev",
        "setup": "Sign in to [Trigger.dev Cloud](https://cloud.trigger.dev) and create a personal access token in the dashboard/account settings flow referenced by the [Management API authentication](https://trigger.dev/docs/management/authentication) docs. The token starts with `tr_pat_` and can authenticate Management API requests; when using it for project-scoped operations you must also provide the target `projectRef` where required by the API/SDK."
      },
      "trigger_public_token": {
        "type": "bearer",
        "label": "Trigger.dev Public Access Token",
        "setup": "Generate a public access token from your backend using `auth.createPublicToken(...)` in the [Realtime auth guide](https://trigger.dev/docs/realtime/auth). Scope it to only the runs, tags, tasks, or sessions your client should access. These tokens are intended for frontend or limited client/backend realtime access, not full project administration."
      },
      "trigger_token": {
        "type": "bearer",
        "label": "Trigger.dev Trigger Token",
        "setup": "Generate a trigger token from your backend following the [Realtime auth guide](https://trigger.dev/docs/realtime/auth#trigger-tokens-for-frontend-triggering-only). These are single-use frontend-safe tokens for triggering tasks from React hooks and related realtime flows."
      },
      "trigger_cli_login": {
        "type": "oauth2",
        "label": "Trigger.dev CLI login session",
        "setup": "Run `npx trigger.dev@latest login` as documented in the [CLI login command](https://trigger.dev/docs/cli-login-commands). This authenticates the Trigger.dev CLI so you can run authenticated commands like deploy and whoami. Use `--api-url` or `TRIGGER_API_URL` if you are targeting a self-hosted or non-default API base."
      }
    },
