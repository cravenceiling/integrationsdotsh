    "credentials": {
      "kensho_refresh_token": {
        "type": "bearer",
        "label": "Kensho refresh token",
        "generateUrl": "https://scribe.kensho.com/account",
        "setup": "For testing/development, mint a refresh token from the product-specific account/login page. The general auth guide says to visit the website for the Kensho API you want; for Scribe it is [Scribe account](https://scribe.kensho.com/account). For the LLM-ready API, the Python auth guide says to sign in at [LLM-ready API Manual Login](https://kfinance.kensho.com/manual_login/) with your LLM-ready API Okta credentials and copy the refresh token. Refresh tokens are product-specific and expire 7 days after last use; exchange them for short-lived access tokens at that product's refresh endpoint before calling APIs.",
        "acquisition": "manual"
      },
      "kensho_keypair_client": {
        "type": "compound",
        "label": "Kensho client ID + private key for JWT client authentication",
        "generateUrl": "mailto:support@kensho.com",
        "setup": "For production, generate an RSA keypair locally, then email Kensho your PEM-encoded public key and the Kensho application(s) you need. The production auth guide says Kensho will respond with your `Client ID`; you then use your private key plus that `Client ID` to obtain access tokens. Start from [Production Authentication](https://docs.kensho.com/authentication/keypair). For the LLM-ready API, the same flow is documented in [kFinance authentication](https://docs.kensho.com/llmreadyapi/python-library/kf-authentication) and access can be requested via [commercial@kensho.com](mailto:commercial@kensho.com).",
        "acquisition": "manual"
      },
      "spg_oauth_client": {
        "type": "oauth2",
        "label": "S&P Global OAuth client credentials for Adaptive Retrieval",
        "generateUrl": "mailto:commercial@kensho.com",
        "setup": "For Adaptive Retrieval, request S&P Global OAuth credentials by emailing [commercial@kensho.com](mailto:commercial@kensho.com). The MCP guide says you need S&P Global OAuth credentials / `CLIENT_ID`, then complete the OAuth flow against the Kensho-hosted MCP/API endpoints.",
        "acquisition": "manual"
      },
      "kensho_lra_access_token": {
        "type": "bearer",
        "label": "Kensho LLM-ready API access token",
        "generateUrl": "https://kfinance.kensho.com/manual_login/",
        "setup": "For temporary experiments or batch jobs, sign in at [LLM-ready API Manual Login](https://kfinance.kensho.com/manual_login/) and copy an access token or refresh token. The docs say the access token expires after one hour and the refresh token after one week.",
        "acquisition": "manual"
      },
      "kensho_lra_oauth_client": {
        "type": "oauth2",
        "label": "LLM-ready API OAuth client",
        "generateUrl": "mailto:support@kensho.com",
        "setup": "For custom MCP/OAuth integrations, if your client supports metadata self-discovery and dynamic client registration, you only need the MCP server URL and the published OAuth metadata at [protected resource metadata](https://kfinance.kensho.com/.well-known/oauth-protected-resource/mcp) and [authorization server metadata](https://kfinance.kensho.com/.well-known/oauth-authorization-server). If your client does not support dynamic client registration, contact [support@kensho.com](mailto:support@kensho.com) to have a client ID provisioned. Kensho can provision either public/private-key or client-secret client authentication; key pairs are preferred.",
        "acquisition": "manual"
      },
