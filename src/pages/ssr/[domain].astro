---
// Worker-SSR'd domain page — served when a STORED discovery exists in KV.
//
// The worker entry rewrites `/{domain}/` here after a KV hit, so returning
// visitors get the discovered map baked into the HTML — already in the "done"
// state, no idle-button flash while the island fetches. (Not underscore-
// prefixed: `_`-files are excluded from Astro routing.) The catalog seed comes
// from the baked /disc/{domain}.json (same build data as the prerendered
// page); the same DomainPage component renders both, so nothing can drift.
import DomainPage from "~/components/DomainPage.astro";
import type { CatalogSection, DiscoverData } from "~/components/Surfaces.tsx";

export const prerender = false;

const runtime = Astro.locals.runtime;
const domain = decodeURIComponent(Astro.params.domain ?? "").trim().toLowerCase();

// Normally reached through the worker's rewrite (which already checked KV),
// but re-read defensively: a direct /ssr/* hit or a KV miss falls back cleanly.
const raw = runtime ? await runtime.env.DISCOVERY.get(domain) : null;
// Parsed KV JSON — the envelope is StoredDiscovery, but old rows predate strict
// typing, so read it as the loose render shape and let the island stay lenient.
const stored = raw ? (JSON.parse(raw) as { result?: DiscoverData }) : null;
const initialData: DiscoverData | null = stored?.result?.surfaces ? stored.result : null;

let catalog: CatalogSection[] = [];
if (runtime) {
  const res = await runtime.env.ASSETS.fetch(
    new URL(`/disc/${encodeURIComponent(domain)}.json`, Astro.url.origin).href,
  );
  if (res.ok) catalog = ((await res.json()) as { catalog?: CatalogSection[] }).catalog ?? [];
}

// Nothing stored and nothing cataloged → true 404.
if (!initialData && !catalog.length) return new Response(null, { status: 404 });

Astro.response.headers.set("cache-control", "public, max-age=60");
---

<DomainPage domain={domain} catalog={catalog} initialData={initialData} />
