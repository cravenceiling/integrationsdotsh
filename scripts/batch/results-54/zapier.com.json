    "summary": "Mapped Zapier’s developer integration surface: 2 HTTP APIs (SDK API and Workflow API), 1 MCP server, and 1 CLI; all require Zapier-issued credentials.",
    "credentials": {
      "zapier_sdk_cli_login": {
        "type": "oauth2",
        "label": "Zapier SDK CLI login session",
        "generateUrl": "https://docs.zapier.com/sdk/using-the-cli",
        "setup": "Install the CLI (`npm install -g @zapier/zapier-sdk-cli` or add `@zapier/zapier-sdk-cli` as a dev dependency), then run `zapier-sdk login` if you already have a Zapier account or `zapier-sdk signup` to create one. The SDK docs state `npx zapier-sdk login` / `npx zapier-sdk signup` also authenticate the SDK automatically via the CLI session. See [Using the CLI](https://docs.zapier.com/sdk/using-the-cli) and [API Reference](https://docs.zapier.com/sdk/reference)."
      },
      "zapier_sdk_client_credentials": {
        "type": "oauth2_cc",
        "label": "Zapier SDK client credentials",
        "generateUrl": "https://docs.zapier.com/sdk/reference",
        "setup": "Create server-side credentials by running `npx zapier-sdk create-client-credentials`. The SDK docs say this returns a `clientId` and `clientSecret` for server/serverless use with `createZapierSdk({ credentials: { clientId, clientSecret } })`. Manage them with the CLI commands documented in [API Reference](https://docs.zapier.com/sdk/reference) and [CLI Reference](https://docs.zapier.com/sdk/cli-reference)."
      },
      "zapier_mcp_connection_token": {
        "type": "bearer",
        "label": "Zapier MCP connection token",
        "generateUrl": "https://mcp.zapier.com",
        "setup": "Open [mcp.zapier.com](https://mcp.zapier.com), select your server, open the **Connect** tab, and click **Generate token**. Copy the token immediately; the docs say it is shown only once. This token is for unlisted/custom MCP clients and can be rotated later from the same Connect tab. See [MCP Authentication](https://docs.zapier.com/mcp/authentication)."
      },
      "zapier_mcp_api_key": {
        "type": "api_key",
        "label": "Zapier MCP API key",
        "generateUrl": "https://mcp.zapier.com",
        "setup": "Open [mcp.zapier.com](https://mcp.zapier.com), select your server, open the **Connect** tab, choose **TypeScript** or **Python** as your client, then under **Step 1: Get Your API Key** click **Generate API Key**. The docs say to send it as `Authorization: Bearer <YOUR_MCP_API_KEY>` to the MCP connect endpoint. See [MCP Authentication](https://docs.zapier.com/mcp/authentication)."
      },
      "zapier_workflow_oauth_app": {
        "type": "oauth2",
        "label": "Zapier Workflow API OAuth app",
        "generateUrl": "https://developer.zapier.com/",
        "setup": "Publish a public integration in the [Zapier Developer Platform](https://developer.zapier.com/). Then in `Embed` → `Settings`, add your redirect URI under `Redirect URIs` and get your `Client ID` and `Client Secret` under `Credentials`. Start the authorization-code flow against `https://api.zapier.com/v2/authorize`, requesting the scopes your use case needs, then exchange the code for a user access token. See [User Access Token](https://docs.zapier.com/powered-by-zapier/authentication/methods/user-access-token) and [OAuth Scopes](https://docs.zapier.com/powered-by-zapier/api-reference/oauth-scopes)."
      }
    },
