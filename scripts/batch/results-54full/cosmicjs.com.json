        "acquisition": "manual"
      },
      "agent_access_token": {
        "type": "jwt",
        "label": "Agent signup access token",
        "generateUrl": "https://www.cosmicjs.com/docs/api/agents",
        "setup": "Call [`POST /v3/agents/sign-up`](https://www.cosmicjs.com/docs/api/agents#sign-up) to provision an agent-created project. The response includes an `access_token` JWT for the shadow user. Refresh it by calling [`GET /v3/agents/status`](https://www.cosmicjs.com/docs/api/agents#status) with your `agent_key`; after verification, [`POST /v3/agents/verify`](https://www.cosmicjs.com/docs/api/agents#verify) returns a fresh longer-lived token. This token is for standard dashboard API calls on the agent-created project.",
        "acquisition": "manual"
