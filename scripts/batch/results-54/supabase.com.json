    "summary": "Found 5 developer surfaces for supabase.com: Management API, Data REST API, GraphQL API, hosted MCP server, and the Supabase CLI; auth is via Supabase PATs, Supabase OAuth app tokens, project API keys, and MCP browser-based OAuth login.",
    "credentials": {
      "supabase_pat": {
        "type": "bearer",
        "label": "Supabase personal access token",
        "generateUrl": "https://supabase.com/dashboard/account/tokens",
        "setup": "In the [Supabase account tokens page](https://supabase.com/dashboard/account/tokens), create a personal access token (PAT). Supabase documents PATs as long-lived tokens for the Management API and for `supabase login`. Keep it secret; it carries your account privileges.",
        "acquisition": "manual"
      },
      "supabase_oauth_app": {
        "type": "oauth2",
        "label": "Supabase OAuth app for integrations",
        "generateUrl": "https://supabase.com/dashboard/account/tokens",
        "setup": "To build a third-party integration, follow [Build a Supabase Integration](https://supabase.com/docs/guides/integrations/build-a-supabase-oauth-integration) to register an OAuth app and obtain user-authorized access tokens with Supabase scopes. Supabase's Management API reference states OAuth2 tokens can be used instead of PATs. Use the integration guide for the app registration and consent flow.",
        "acquisition": "manual"
      },
      "supabase_project_api_key": {
        "type": "api_key",
        "label": "Supabase project API key",
        "generateUrl": "https://supabase.com/dashboard/project/_/settings/api-keys/",
        "setup": "Open your project's [API Keys settings](https://supabase.com/dashboard/project/_/settings/api-keys/) in the Supabase Dashboard and copy the project key you need. Supabase's docs say GraphQL requires the `apiKey` header on every request, and the Data REST API keys are also found on this page. For local development, `supabase start` prints local publishable and secret keys.",
        "acquisition": "manual"
      },
      "supabase_mcp_oauth": {
        "type": "oauth2",
        "label": "Supabase MCP hosted-server login",
        "setup": "Configure an MCP client for `https://mcp.supabase.com/mcp`, then authenticate from the client. Supabase's MCP guide says clients open a browser window where you log in to your Supabase account and grant organization access to the MCP client; hosted MCP no longer requires a PAT. For Claude Code, add the server then run `claude /mcp` and choose Authenticate.",
        "acquisition": "manual"
      }
    },
