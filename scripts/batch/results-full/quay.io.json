        "generateUrl": "https://docs.quay.io/api/",
        "setup": "Create an application under your organization’s **Applications** tab in Quay, then run the OAuth web flow to mint an access token. For a browser flow, Quay directs users to `https://quay.io/oauth/authorize?...`; for internal use you can also click **Generate Token** on the application page. Use the resulting token as a bearer token for API calls and `docker login`."
      },
      "quay_robot_account_token": {
        "type": "bearer",
        "label": "Quay robot account token",
        "generateUrl": "https://docs.redhat.com/en/documentation/red_hat_quay/3/html-single/red_hat_quay_api_guide/index",
        "setup": "Create or manage a robot account in Quay, then use the robot account token for registry and API authentication where supported. Quay’s docs describe robot account tokens as the replacement for deprecated access tokens. If you need to refresh it, regenerate the robot token from the UI or via the API on supported installations."
      },
      "quay_access_token_deprecated": {
        "type": "basic",
        "label": "Quay access token (deprecated)",
        "generateUrl": "https://docs.quay.io/glossary/access-token.html",
        "setup": "Deprecated: create a repository access token from the repository’s view/panel. Quay says access tokens are the replacement for passwords for per-repository auth, but they are deprecated in favor of robot accounts. Use the token value as the password with username `$token` in `docker login`."
      }
