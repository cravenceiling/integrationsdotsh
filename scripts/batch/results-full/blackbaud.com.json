        "type": "api_key",
        "label": "SKY API subscription key",
        "generateUrl": "https://developer.blackbaud.com/subscriptions",
        "setup": "Create a [SKY Developer account](https://developer.blackbaud.com/signup), then go to [My subscriptions](https://developer.blackbaud.com/subscriptions) and subscribe to the needed SKY API product (for example, Standard APIs or Payments API). Blackbaud issues subscription access keys there; copy the `Primary` or `Secondary` key and store it securely. Send it on every SKY API request in the `Bb-Api-Subscription-Key` header.",
        "acquisition": "manual"
      },
      "bb_oauth_app": {
        "type": "oauth2",
        "label": "SKY application credentials",
        "generateUrl": "https://developer.blackbaud.com/apps",
        "setup": "Create a [SKY application](https://developer.blackbaud.com/apps) from [My applications](https://developer.blackbaud.com/apps). Blackbaud assigns an Application ID and one or more Application Secrets. Use these to request user consent and exchange authorization codes for access tokens. Register exact `redirect_uri` values in the app settings; for confidential apps, keep the secret server-side. For public/browser/native apps, use PKCE and avoid storing a client secret.",
        "acquisition": "manual"
      },
      "bb_oauth_access_token": {
        "type": "bearer",
        "label": "SKY API access token",
        "generateUrl": "https://developer.blackbaud.com/skyapi/docs/authorization",
        "setup": "Obtain this token through SKY API OAuth 2.0 after the user consents to your application. For confidential apps, exchange the authorization code at [https://oauth2.sky.blackbaud.com/token](https://oauth2.sky.blackbaud.com/token); for public apps, use PKCE and do not require a client secret. The token is issued per user and organization and is used as a Bearer token in the `Authorization` header.",
        "acquisition": "manual"
      }
    },
