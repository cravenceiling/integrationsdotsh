        "generateUrl": "https://signoz.io/docs/manage/administrator-guide/iam/service-accounts/",
        "setup": "In SigNoz, go to [Service Accounts](https://signoz.io/docs/manage/administrator-guide/iam/service-accounts/). Create or open a service account under **Settings > Service Accounts**, then open its **Keys** tab and click **Add Key**. Copy the key value when it is shown; SigNoz says the value is shown only once. Use it in the `SIGNOZ-API-KEY` header for API requests.",
        "acquisition": "manual"
      },
      "ingestion_key": {
        "type": "api_key",
        "label": "SigNoz Cloud ingestion key",
        "generateUrl": "https://signoz.io/docs/ingestion/signoz-cloud/overview/",
        "setup": "Sign up for or log in to [SigNoz Cloud](https://signoz.io/teams/), then go to [Ingestion Overview for SigNoz Cloud](https://signoz.io/docs/ingestion/signoz-cloud/overview/) and create an ingestion key from **Settings > Ingestion** (or follow the linked keys page from there). Use the key with OTLP exporters via the `signoz-ingestion-key` header, or configure `OTEL_EXPORTER_OTLP_HEADERS=signoz-ingestion-key=<key>` for many OpenTelemetry SDKs.",
        "acquisition": "manual"
      },
