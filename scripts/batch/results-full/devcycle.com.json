        "type": "oauth2_cc",
        "label": "DevCycle OAuth client credentials token",
        "generateUrl": "https://app.devcycle.com/r/settings",
        "setup": "Go to the [DevCycle dashboard settings](https://app.devcycle.com/r/settings) and use your organization's OAuth client id and client secret to mint an access token from `https://auth.devcycle.com/oauth/token` with `grant_type=client_credentials` and `audience=https://api.devcycle.com/`. For Enterprise RBAC setups, DevCycle notes a different token request using `grant_type=refresh_token` and a refresh token.",
        "acquisition": "manual"
      },
      "dvc_cli_sso": {
        "type": "bearer",
        "label": "DevCycle CLI / MCP SSO access token",
