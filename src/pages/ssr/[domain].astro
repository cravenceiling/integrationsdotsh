---
// Worker-SSR'd domain page — served when a STORED discovery exists in KV.
//
// The worker entry rewrites `/{domain}/` here after a KV hit, so returning
// visitors get the discovered map baked into the HTML — already in the "done"
// state, no idle-button flash while the island fetches. (Not underscore-
// prefixed: `_`-files are excluded from Astro routing.) KV wins; the baked
// /disc/{domain}.json baseline is the discovery fallback. The same DomainPage
// component renders both, so nothing can drift.
import DomainPage from "~/components/DomainPage.astro";
import { aliasesOf, canonicalDomain } from "~/lib/domain-aliases.ts";
import type { DiscoverData } from "~/lib/surface-sections.ts";

export const prerender = false;

const runtime = Astro.locals.runtime;
const domain = canonicalDomain(decodeURIComponent(Astro.params.domain ?? ""));

// Normally reached through the worker's rewrite (which already checked KV),
// but re-read defensively: a direct /ssr/* hit or a KV miss falls back cleanly.
const raw = runtime
  ? await (async () => {
      const stored = await runtime.env.DISCOVERY.get(domain);
      if (stored) return stored;
      for (const alias of aliasesOf(domain)) {
        const aliasStored = await runtime.env.DISCOVERY.get(alias);
        if (aliasStored) return aliasStored;
      }
      return null;
    })()
  : null;
// Parsed KV JSON — the envelope is StoredDiscovery, but old rows predate strict
// typing, so read it as the loose render shape and let the island stay lenient.
const stored = raw ? (JSON.parse(raw) as { result?: DiscoverData; discoveredAt?: string }) : null;
let initialData: DiscoverData | null = stored?.result?.surfaces
  ? { ...stored.result, discoveredAt: stored.result.discoveredAt ?? stored.discoveredAt }
  : null;

if (!initialData && runtime) {
  const res = await runtime.env.ASSETS.fetch(
    new URL(`/disc/${encodeURIComponent(domain)}.json`, Astro.url.origin).href,
  );
  if (res.ok) {
    const baseline = (await res.json()) as DiscoverData;
    if (baseline.surfaces?.length) initialData = baseline;
  }
}

// No KV and no baseline discovery surfaces → true 404.
if (!initialData) return new Response(null, { status: 404 });

Astro.response.headers.set("cache-control", "public, max-age=60");
---

<DomainPage domain={domain} initialData={initialData} />
