    "summary": "Stitch exposes two documented REST APIs—the Import API and the Stitch Connect API—and a deprecated browser JavaScript client for embedded Connect workflows; all documented developer surfaces require Stitch-issued credentials.",
    "description": "Stitch is a cloud data integration service for moving data from sources into destinations. It provides an Import API for pushing arbitrary data into Stitch and a Connect product for programmatically managing Stitch accounts and source configuration.",
    "credentials": {
      "import_api_token": {
        "type": "bearer",
        "label": "Import API access token",
        "generateUrl": "https://www.stitchdata.com/docs/developers/import-api/guides/manage-import-api-access-tokens",
        "setup": "Sign into the [Stitch app](https://app.stitchdata.com), click **Add Integration**, choose **Import API**, enter an integration name, and click **Save and Generate Token**. Copy the token when it is shown; Stitch only displays it once. The step-by-step guide is in [Managing and Revoking Import API Access Tokens in Stitch](https://www.stitchdata.com/docs/developers/import-api/guides/manage-import-api-access-tokens)."
      },
      "connect_access_token": {
        "type": "bearer",
        "label": "Stitch Connect API access token",
        "generateUrl": "https://www.stitchdata.com/docs/developers/stitch-connect/guides/stitch-partner-authentication-guide",
        "setup": "There are two documented ways to obtain a Connect API access token. For your own Stitch account, use the Connect API credentials flow described in the [Connect API authentication reference](https://www.stitchdata.com/docs/developers/stitch-connect/api#authentication-overview). For Stitch partners acting on behalf of customer accounts, first request partner access via the [contact form](https://www.stitchdata.com/contact/); once approved, use your `partner_id` and `partner_secret` either to create a new account with `POST /v3/accounts` or to complete the OAuth2 flow described in the [Stitch Partner API Authentication Guide](https://www.stitchdata.com/docs/developers/stitch-connect/guides/stitch-partner-authentication-guide). Store the returned `access_token` and send it as a bearer token.",
        "acquisition": "manual"
      },
      "stitch_partner_app": {
        "type": "app",
        "label": "Stitch partner application credentials (`partner_id` and `partner_secret`)",
        "generateUrl": "https://www.stitchdata.com/contact/",
        "setup": "This is only for Stitch partners / API clients. Complete the [Stitch contact form](https://www.stitchdata.com/contact/) to request partner access. After approval, Stitch issues a `partner_id` and `partner_secret`. These are used to create customer Stitch accounts with `POST /v3/accounts`, and `partner_id` also serves as the OAuth `client_id` in the partner flow documented in the [Stitch Partner API Authentication Guide](https://www.stitchdata.com/docs/developers/stitch-connect/guides/stitch-partner-authentication-guide)."
      }
