        "generateUrl": "https://amplitude.com/docs/en/apis/authentication",
        "setup": "In the Amplitude web app, go to **Settings** → **Projects**, select your project, then on the **General** tab use **Manage** next to **API Key** to view/copy it. Managers and Admins can generate, copy, and revoke keys. See [API Authentication](https://amplitude.com/docs/en/apis/authentication) and [Keys and Tokens](https://amplitude.com/docs/en/apis/keys-and-tokens)."
      },
      "project_secret_key": {
        "type": "basic",
        "label": "Project Secret Key",
        "generateUrl": "https://amplitude.com/docs/en/apis/authentication",
        "setup": "In the Amplitude web app, go to **Settings** → **Projects**, select your project, then on the **General** tab use **Manage** next to **Secret Key** to generate and copy it. Amplitude only shows a secret key when you generate it. See [API Authentication](https://amplitude.com/docs/en/apis/authentication) and [Keys and Tokens](https://amplitude.com/docs/en/apis/keys-and-tokens)."
      },
      "data_api_token": {
        "type": "bearer",
        "label": "Data API Token",
        "generateUrl": "https://amplitude.com/docs/en/apis/keys-and-tokens",
        "setup": "In Amplitude Data, go to **Data** → **Settings** → **API Tokens** to create or revoke a token. These tokens grant the same roles and permissions you have when logging in directly. See [Keys and Tokens](https://amplitude.com/docs/en/apis/keys-and-tokens)."
      },
      "experiment_deployment_key": {
        "type": "api_key",
        "label": "Experiment Deployment Key",
        "generateUrl": "https://amplitude.com/docs/en/apis/keys-and-tokens",
        "setup": "In Amplitude Experiment, create or open a deployment in **Experiment** → **Deployments** and copy its Deployment Key. Client-side keys are public and prefixed `client-`; server-side keys are private and prefixed `server-`. See [Keys and Tokens](https://amplitude.com/docs/en/apis/keys-and-tokens)."
      },
      "experiment_management_api_key": {
        "type": "bearer",
        "label": "Experiment Management API Key",
        "generateUrl": "https://amplitude.com/docs/en/apis/experiment/experiment-management-api",
        "setup": "In Amplitude Experiment, use **Management API** in the Experiment sidebar to create and manage Management API keys. See [Experiment Management API](https://amplitude.com/docs/en/apis/experiment/experiment-management-api) and [Keys and Tokens](https://amplitude.com/docs/en/apis/keys-and-tokens)."
      },
      "scim_key": {
        "type": "bearer",
        "label": "SCIM Key",
        "generateUrl": "https://amplitude.com/docs/en/admin/account-management/scim-provision",
        "setup": "Set up SCIM in Amplitude and rotate/copy the SCIM key in your organization's SCIM provisioning settings. SCIM is available on Enterprise plans. See [Set up SCIM provisioning in Amplitude](https://amplitude.com/docs/en/admin/account-management/scim-provision) and [Keys and Tokens](https://amplitude.com/docs/en/apis/keys-and-tokens)."
      },
      "org_api_key": {
        "type": "basic",
        "label": "Organization API Key",
        "generateUrl": "https://amplitude.com/docs/en/apis/audit-logs",
        "setup": "Find your Organization API key in **Organization settings** → **API Keys**. Some org-level APIs require it together with an Organization Secret Key. See [Audit Logs API](https://amplitude.com/docs/en/apis/audit-logs) and [Keys and Tokens](https://amplitude.com/docs/en/apis/keys-and-tokens)."
      },
      "amplitude_account_oauth": {
        "type": "oauth2",
        "label": "Amplitude account OAuth login",
        "setup": "Authenticate to the remote MCP server by connecting your MCP client to `https://mcp.amplitude.com/mcp` (or EU `https://mcp.eu.amplitude.com/mcp`) and signing in with your Amplitude account when prompted. The docs state the server uses OAuth 2.0 and requires an active Amplitude account with project access. See [Amplitude MCP Server](https://amplitude.com/docs/en/amplitude-ai/amplitude-mcp) and [Other clients](https://amplitude.com/docs/en/amplitude-ai/amplitude-mcp/other-clients)."
      },
      "wizard_login_session": {
        "type": "oauth2",
        "label": "Amplitude Wizard CLI login session",
        "generateUrl": "https://amplitude.com/docs/en/get-started/setup-wizard-cli",
        "setup": "Run `npx @amplitude/wizard login` when the wizard prompts for authentication, then complete the browser sign-in flow and resume the command. The wizard can also expose the current token with `npx @amplitude/wizard auth token`. See [Amplitude Wizard CLI](https://amplitude.com/docs/en/get-started/setup-wizard-cli) and [llms-full.txt](https://amplitude.com/llms-full.txt)."
      }
