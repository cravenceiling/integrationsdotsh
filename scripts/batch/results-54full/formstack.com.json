    "summary": "Formstack exposes three documented REST API surfaces: the current Formstack API v2025 (PAT bearer auth), the legacy Formstack API v2 (OAuth2 bearer or GET query token), and the legacy Formstack Documents/WebMerge API (Basic auth with API key + secret); it also documents a SCIM API but its auth mechanics were not found in the scraped pages. No public GraphQL, MCP, or CLI surfaces were found.",
    "description": "Formstack is a no-code productivity platform for building forms, generating documents, and collecting eSignatures, with workflow automation and Salesforce-focused offerings. It serves businesses that need to digitize data collection and related approval or document processes.",
    "credentials": {
      "webmerge_api_basic": {
        "type": "basic",
        "label": "Formstack Documents API key and secret",
        "generateUrl": "https://www.webmerge.me/developers/authentication",
        "setup": "In [Formstack Documents API authentication](https://www.webmerge.me/developers/authentication), Formstack says each user must create an API key from their account page; when the key is generated, a matching secret is also generated. Use the `Key:Secret` pair for Basic HTTP authentication to the Documents API.",
        "acquisition": "manual"
      },
      "formstack_pat": {
        "type": "bearer",
        "label": "Formstack Personal Access Token",
        "generateUrl": "https://help.formstack.com/s/article/Formstack-Personal-Access-Tokens",
        "setup": "Create a Personal Access Token by following [Formstack Personal Access Tokens](https://help.formstack.com/s/article/Formstack-Personal-Access-Tokens). The developer docs state all v2025 API calls require a PAT, and requests send it as `Authorization: Bearer fs_pat_<your-personal-access-token>`.",
        "acquisition": "manual"
      },
      "formstack_oauth_app": {
        "type": "oauth2",
        "label": "Formstack OAuth app access token",
        "generateUrl": "https://www.formstack.com/admin/apiKey/main",
        "setup": "Create an application record at [Formstack application management](https://www.formstack.com/admin/apiKey/main). The v2 docs say creating an application also creates an access token, and additional user access tokens can be minted through the OAuth2 authorization flow documented in [Authorization](https://developers.formstack.com/v2.0/reference/authorization). Use the resulting OAuth2 access token as a bearer token, or as `oauth_token` on GET requests where supported.",
        "acquisition": "manual"
      }
    },
