{
  "name": "integrations",
  "version": "0.0.1-beta.3",
  "description": "CLI for integrations.sh — search the registry of agent integrations and read a domain's surface.",
  "type": "module",
  "bin": {
    "integrations": "dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UsefulSoftwareCo/integrations.git",
    "directory": "cli"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "bun build src/cli.ts --target node --outdir dist && chmod +x dist/cli.js",
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "integrations",
    "mcp",
    "openapi",
    "graphql",
    "agents",
    "registry",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
