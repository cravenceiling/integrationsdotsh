      "gel_db_password": {
        "type": "basic",
        "label": "Gel database username and password",
        "setup": "Create or set a database role password on your Gel instance. The docs note Gel creates an `admin` user by default with a randomized password, and you can set one with `alter role admin { set password := '<password>'; };` or create a new role with `create superuser role <name> { set password := '<password>'; };`. For linked or local instances, the CLI can also save these credentials locally as described in [Connection parameters](https://docs.geldata.com/reference/using/connection.md).",
        "acquisition": "manual"
      },
      "gel_db_jwt": {
        "type": "jwt",
        "label": "Gel database JWT for SIMPLE_HTTP transport",
        "setup": "Configure your Gel instance to use `cfg::JWT` for the `SIMPLE_HTTP` transport as described in [EdgeQL over HTTP](https://docs.geldata.com/reference/using/http.md). Then mint a JWT for a Gel database user according to your instance's JWT configuration. Requests must include `Authorization: Bearer <token>` and `X-EdgeDB-User: <gel-username>`.",
        "acquisition": "manual"
      }
