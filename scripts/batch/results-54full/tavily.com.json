        "type": "oauth2",
        "label": "Tavily OAuth authorization for remote MCP/CLI",
        "generateUrl": "https://mcp.tavily.com/mcp/",
        "setup": "Use a compatible client that can complete Tavily's OAuth flow against the remote MCP server, such as running `tvly login` from the CLI or adding the remote MCP URL in Claude Code with `claude mcp add tavily-remote-mcp --transport http https://mcp.tavily.com/mcp/`. Tavily's docs say the client opens a browser to authorize access to your Tavily account, and tokens are then stored locally by the client (for example in `~/.mcp-auth/` for the CLI / `mcp-remote` flow).",
        "acquisition": "manual"
      }
