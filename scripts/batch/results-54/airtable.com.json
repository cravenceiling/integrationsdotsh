    "summary": "Found 2 developer integration surfaces for airtable.com: a token-authenticated HTTP Web API at https://api.airtable.com and an MCP server at https://mcp.airtable.com/mcp; both accept Airtable-issued personal access tokens, and Airtable OAuth integrations can also authenticate (OAuth for Web API, OAuth/well-known for MCP).",
    "credentials": {
      "airtable_pat": {
        "type": "bearer",
        "label": "Personal Access Token",
        "generateUrl": "https://airtable.com/create/tokens",
        "setup": "Open the [Developer Hub](https://airtable.com/create/tokens), choose **Personal access tokens**, click **Create token**, then add the scopes and base/workspace resources the token should access. Airtable sends this token as an HTTP `Authorization: Bearer` token. Enterprise admins can also mint PATs for service accounts from the [service accounts admin flow](https://support.airtable.com/docs/service-accounts-overview)."
      },
      "airtable_oauth_app": {
        "type": "oauth2",
        "label": "OAuth integration (client id, optional client secret, and user-granted access token)",
        "generateUrl": "https://airtable.com/create/oauth",
        "setup": "Open the [OAuth integrations panel](https://airtable.com/create/oauth), click **Register new OAuth integration**, set a name and redirect URI, and choose the scopes your app will request. For server-side token exchange you can generate an optional client secret from the integration management page. Then run Airtable's OAuth flow using the authorization endpoint `https://airtable.com/oauth2/v1/authorize` and token endpoint `https://airtable.com/oauth2/v1/token`; Airtable can also create clients dynamically at `https://airtable.com/oauth2/v1/register`. Add Privacy Policy and Terms of Service URLs before sharing the integration with other users."
      }
    },
