    "summary": "Bugsnag exposes five authenticated HTTP APIs (Data Access via `Authorization: token <Personal Auth Token>`; Build, Error Reporting, Session Tracking, Trace, and Upload via project API keys) plus an authenticated Bugsnag CLI and SmartBear MCP access (remote via SmartBear OAuth, local via `BUGSNAG_AUTH_TOKEN` and optional `BUGSNAG_PROJECT_API_KEY`).",
    "credentials": {
      "bugsnag_pat": {
        "type": "bearer",
        "label": "BugSnag Personal Auth Token",
        "generateUrl": "https://app.bugsnag.com/settings/smartbear-software/my-account/auth-tokens",
        "setup": "In the BugSnag dashboard, open [My Account Auth Tokens](https://app.bugsnag.com/settings/smartbear-software/my-account/auth-tokens) and generate a new Personal Auth Token. Use it in API calls as an `Authorization` header with the `token` prefix, for example `Authorization: token YOUR_AUTH_TOKEN`. This token is also used by BugSnag tools in the local SmartBear MCP server via `BUGSNAG_AUTH_TOKEN`.",
        "acquisition": "manual"
      },
      "bugsnag_project_api_key": {
        "type": "api_key",
        "label": "BugSnag project API key",
        "setup": "Open your project's settings in the BugSnag dashboard; the CLI docs state you can find the API key in your project settings (`g` then `s`). Use this key for build creation, event/session reporting, trace submission, and symbol/mapping uploads. In the local SmartBear MCP server, you can also set it as `BUGSNAG_PROJECT_API_KEY` to scope BugSnag tools to a single project.",
        "acquisition": "manual"
      },
      "smartbear_oauth": {
        "type": "oauth2",
        "label": "SmartBear account OAuth login for remote MCP",
        "setup": "Configure your MCP client to connect to the hosted BugSnag remote MCP endpoint from [Remote MCP Servers](https://developer.smartbear.com/smartbear-mcp/docs/remote-mcp-servers). On first connection, the client opens a browser window for you to sign in with your SmartBear account and authorize access. The MCP client stores and refreshes the token automatically; there is no manual token creation page documented for this flow.",
        "acquisition": "manual"
      }
    },
