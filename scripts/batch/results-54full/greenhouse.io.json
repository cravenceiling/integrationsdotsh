    "summary": "Greenhouse exposes multiple developer surfaces: Harvest API v3, Job Board API, Candidate Ingestion API, Audit Log API, an Onboarding GraphQL API, and an Assessment partner API; authentication varies by API and includes OAuth, Basic auth, and required On-Behalf-Of headers for some flows.",
    "description": "Greenhouse provides recruiting and onboarding software used to manage hiring workflows, job postings, candidates, assessments, and employee onboarding data. Its products include Greenhouse Recruiting, job board publishing, audit logging, and onboarding.",
    "credentials": {
      "harvest_v3_oauth_client": {
        "type": "oauth2_cc",
        "label": "Harvest v3 OAuth client credentials",
        "generateUrl": "https://harvestdocs.greenhouse.io/docs/authentication",
        "setup": "In Greenhouse, open **API Credentials**, click **Create new API credentials**, select **Harvest V3 (OAuth)**, save, and configure the scopes your integration needs, as described in [Harvest authentication](https://harvestdocs.greenhouse.io/docs/authentication). Greenhouse then gives you a `Client ID` and `Client Secret`. Use them to get a bearer token from `https://auth.greenhouse.io/token` with the OAuth client-credentials flow."
      },
      "harvest_partner_oauth_app": {
        "type": "oauth2",
        "label": "Greenhouse Harvest partner OAuth app",
        "generateUrl": "https://harvestdocs.greenhouse.io/docs/harvest-partner-oauth",
        "setup": "This is for signed Greenhouse partners. Start with the [integration request form](https://www.greenhouse.com/integration-partner#apply-now), then work with Greenhouse Partner Support as described in [the Harvest partner OAuth guide](https://harvestdocs.greenhouse.io/docs/harvest-partner-oauth). Provide your integration name, environment, required scopes, redirect URI(s), and logo; Greenhouse issues a `Client ID` and `Client Secret` for the authorization-code flow against `https://auth.greenhouse.io/authorize` and `https://auth.greenhouse.io/token`."
      },
      "harvest_api_key": {
        "type": "basic",
        "label": "Harvest API key",
        "generateUrl": "https://support.greenhouse.io/hc/en-us/articles/5888163769883",
        "setup": "Create a Harvest API credential in Greenhouse from **API Credentials** / **API Credential Management**. The Harvest docs note existing Harvest API credentials can still be used during the v1/v2→v3 transition and for Audit Log token generation; see [Harvest authentication](https://harvestdocs.greenhouse.io/docs/authentication) and [Audit Log authentication](https://developers.greenhouse.io/audit-log.html#authentication). Use the API key as the HTTP Basic username with an empty password (`api_key:`)."
      },
      "job_board_api_key": {
        "type": "basic",
        "label": "Job Board API key",
        "generateUrl": "https://support.greenhouse.io/hc/en-us/articles/5888210160155",
        "setup": "Create a Job Board API credential in Greenhouse API Credentials/API Credential Management. The [Job Board API docs](https://developers.greenhouse.io/job-board.html) state only application submission requires this key. Use the Job Board API key as the HTTP Basic username with an empty password, base64-encoded as `api_key:`."
      },
      "ingestion_partner_oauth_app": {
        "type": "oauth2",
        "label": "Candidate Ingestion OAuth app",
        "generateUrl": "https://developers.greenhouse.io/candidate-ingestion.html#authentication",
        "setup": "For Candidate Ingestion OAuth, provide Greenhouse with your application name, application URL, callback URL, and logo as described in [Candidate Ingestion authentication](https://developers.greenhouse.io/candidate-ingestion.html#authentication). Greenhouse then supplies a consumer key, consumer secret, token URL, and authorize URL for the OAuth 2.0 flow. Use the resulting bearer access token in API requests."
      },
      "partner_api_key": {
        "type": "basic",
        "label": "Partner API key",
        "generateUrl": "https://developers.greenhouse.io/candidate-ingestion.html#authentication",
        "setup": "For Candidate Ingestion basic auth, the customer supplies the partner with a **Partner API Key** and a service user, per [Candidate Ingestion authentication](https://developers.greenhouse.io/candidate-ingestion.html#authentication). Use the Partner API key as the HTTP Basic username with an empty password (`api_key:`), and send the service user's email in the `On-Behalf-Of` header on every request."
      },
      "service_user_email": {
        "type": "compound",
        "label": "Service user email for On-Behalf-Of",
        "setup": "For Candidate Ingestion basic authentication, use the active Greenhouse service user's email address in the `On-Behalf-Of` header on every request, as required by [Candidate Ingestion authentication](https://developers.greenhouse.io/candidate-ingestion.html#authentication). This user is typically created specifically for the integration and must be recognized by Greenhouse."
      },
      "audit_log_user_id": {
        "type": "compound",
        "label": "Greenhouse user ID for Audit Log token generation",
        "setup": "When generating an Audit Log access token, send the Greenhouse user ID in the `On-Behalf-Of` header, as shown in [Audit Log authentication](https://developers.greenhouse.io/audit-log.html#authentication). The request also requires a Harvest API key."
      }
    },
