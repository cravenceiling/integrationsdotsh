        "generateUrl": "https://dashboard.stripe.com/apikeys",
        "setup": "In the [Stripe Dashboard API keys page](https://dashboard.stripe.com/apikeys), create or reveal a secret key for your account. For least-privilege access, create a restricted key from the [restricted API keys docs](https://docs.stripe.com/keys/restricted-api-keys#create-a-restricted-api-key). Use it as an HTTP `Authorization: Bearer <key>` credential. The MCP docs explicitly recommend restricted keys for Connect use cases."
      },
      "stripe_cli_login": {
        "type": "api_key",
        "label": "Stripe CLI-created local API key",
        "generateUrl": "https://docs.stripe.com/cli/login",
        "setup": "Install the [Stripe CLI](https://docs.stripe.com/stripe-cli), then run `stripe login`. Stripe redirects you to the Dashboard to authorize the CLI and creates a new API key for the CLI, storing it in `~/.config/stripe/config.toml`. You can also use `stripe login --interactive` to paste an existing API key manually.",
        "acquisition": "manual"
      },
      "stripe_sandbox_key": {
        "type": "api_key",
        "label": "Temporary Stripe sandbox secret key",
        "generateUrl": "https://docs.stripe.com/cli",
        "setup": "Run `stripe sandbox create --email <you@example.com>` or `stripe sandbox create --from-git` with the [Stripe CLI reference](https://docs.stripe.com/cli). Stripe provisions a 7-day sandbox and prints a temporary `secret_key` plus `publishable_key`; the secret key can be used for API and CLI calls until the sandbox expires or is claimed.",
        "acquisition": "manual"
      }
