        "generateUrl": "https://dashboard.razorpay.com/app/keys",
        "setup": "Go to the [Razorpay Dashboard](https://dashboard.razorpay.com/app/keys), open **Account & Settings → API Keys**, choose **Test** or **Live**, and click **Generate Key**. Save the `Key ID` and `Key Secret` securely; the secret is shown only once. Use Test keys while developing and Live keys for production.",
        "acquisition": "manual"
      },
      "rzp_oauth_client": {
        "type": "oauth2",
        "label": "Razorpay MCP OAuth client (client_id + client_secret)",
        "generateUrl": "https://mcp.razorpay.com/register",
        "setup": "Register an OAuth client with Razorpay MCP. The easiest path is Dynamic Client Registration: `POST` to `https://mcp.razorpay.com/register` with your client details, or use the documented OAuth setup flow from the MCP docs. The response returns a `client_id` and `client_secret`; store them securely and use them to obtain tokens for the `read_only` scope. If you prefer a manual route, Razorpay also documents contacting support for client issuance.",
        "acquisition": "manual"
      },
      "rzp_oauth_token": {
        "type": "bearer",
        "label": "Razorpay MCP OAuth access token",
        "generateUrl": "https://mcp.razorpay.com/authorize",
        "setup": "Complete the Razorpay MCP OAuth flow to mint an access token. Use the Authorization Code flow with PKCE via `https://mcp.razorpay.com/authorize` and `https://mcp.razorpay.com/token`, or client credentials against `https://mcp.razorpay.com/token` where supported. Request the `read_only` scope. The token is short-lived (the docs describe 3600-second expiry) and is used to call MCP tools.",
        "acquisition": "manual"
      }
