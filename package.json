{
  "name": "integrationsdotsh",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "normalize": "bun scripts/normalize.ts",
    "extract-tools": "bun scripts/extract-tools.ts",
    "validate-favicons": "bun scripts/validate-favicons.ts",
    "dev": "bun run normalize && astro dev",
    "build": "bun run normalize && astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "cf:dev": "wrangler dev",
    "cf:deploy": "bun run build && wrangler deploy",
    "cf:deploy-only": "wrangler deploy",
    "cf:setup-domain": "bun scripts/setup-cloudflare-domain.ts"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.4",
    "@executor-js/config": "^0.0.2",
    "@executor-js/plugin-graphql": "^0.0.2",
    "@executor-js/plugin-mcp": "^0.0.2",
    "@executor-js/plugin-openapi": "^0.0.2",
    "@executor-js/sdk": "^0.0.2",
    "@executor-js/storage-core": "^0.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^5.0.0",
    "effect": "4.0.0-beta.91",
    "marked": "^18.0.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tldts": "^7.0.29"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^22.0.0",
    "pagefind": "^1.1.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.87.0"
  }
}