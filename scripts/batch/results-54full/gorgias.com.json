    "summary": "Gorgias exposes a tenant-scoped REST API authenticated by either Basic auth with a user API key or OAuth2 bearer tokens, plus a hosted MCP server at `https://mcp.gorgias.com/mcp` that users authorize with their Gorgias account.",
    "description": "Gorgias provides a customer support and conversational AI platform for ecommerce brands. Its products center on a helpdesk, automation, and AI tools for handling support interactions and related account configuration.",
    "credentials": {
      "rest_api_key": {
        "type": "basic",
        "label": "Gorgias REST API key with account email",
        "generateUrl": "https://docs.gorgias.com/en-US/rest-api-208286",
        "setup": "In your Gorgias helpdesk, go to **Settings → Account → REST API** and click **Create API key** if needed. Copy the **Base API URL** (`https://{your-domain}.gorgias.com/api/`), your account **Username** (email), and the **Password (API Key)** from the REST API page as described in [Access your Gorgias REST API credentials](https://docs.gorgias.com/en-US/rest-api-208286). Requests use HTTP Basic auth with the email as username and the API key as password; Gorgias also documents this in [Access Tokens (API Keys)](https://developers.gorgias.com/docs/access-tokens-api-keys)."
      },
      "oauth_app": {
        "type": "oauth2",
        "label": "Gorgias OAuth2 app credentials and resulting bearer tokens",
        "generateUrl": "https://partners.gorgias.com/signup",
        "setup": "For a public app, sign up for the [Gorgias Developer Portal](https://partners.gorgias.com/signup), create a draft app, and obtain its `Client ID` and `Client Secret` as described in [3. Set up OAuth2](https://developers.gorgias.com/docs/set-up-oauth2-app-store). Your app then uses Gorgias's OAuth2 flow to get bearer `access_token` and `refresh_token` values for a customer's `{subdomain}.gorgias.com` account. OAuth2 is required for public apps per [OAuth2 Bearer Token](https://developers.gorgias.com/docs/oauth2-bearer-token)."
      }
    },
