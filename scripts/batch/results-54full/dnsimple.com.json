        "generateUrl": "https://support.dnsimple.com/articles/api-access-token/",
        "setup": "In the DNSimple app, open your account's API & Access page from [dnsimple.com/user](https://dnsimple.com/user) for production or [sandbox.dnsimple.com/user](https://sandbox.dnsimple.com/user) for sandbox, click **Add**, name the token, optionally choose scopes on eligible plans, then click **Generate token**. Copy the token immediately because it is shown only once. Use it as `Authorization: Bearer {TOKEN}`.",
        "acquisition": "manual"
      },
      "oauth_app": {
        "type": "oauth2",
        "label": "DNSimple OAuth application (client ID and secret)",
        "generateUrl": "https://support.dnsimple.com/articles/oauth-applications/",
        "setup": "Register an OAuth application from the DNSimple app as described in [OAuth Applications](https://support.dnsimple.com/articles/oauth-applications/). DNSimple assigns a `client_id`; confidential web apps also receive a `client_secret`. Public clients use PKCE instead of a secret and may require contacting DNSimple support to enable public-client registration, per the [OAuth docs](https://developer.dnsimple.com/v2/oauth/).",
        "acquisition": "manual"
      },
      "user_basic": {
        "type": "basic",
        "label": "DNSimple user email and password",
        "setup": "Use your DNSimple account email and password. The API overview documents HTTP Basic Authentication with `EMAIL:PASSWORD`; if your account has two-factor authentication enabled, also send an OTP in the `X-Dnsimple-OTP` header. This is an end-user account credential rather than a recommended integration token; DNSimple prefers OAuth or access tokens.",
        "acquisition": "manual"
      }
