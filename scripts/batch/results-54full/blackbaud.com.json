    "summary": "Blackbaud exposes a REST integration surface called SKY API at `https://api.sky.blackbaud.com`, authenticated with both a SKY API subscription key and an OAuth 2.0 bearer token, and it also has a catalog-listed MCP server at `https://mcp.sky.blackbaud.com/` with unknown public auth details.",
    "description": "Blackbaud provides software and cloud services for nonprofits, education, fundraising, grantmaking, finance, and related social-good operations. Its SKY Developer program offers APIs and related developer tooling for integrating with Blackbaud customer environments.",
    "credentials": {
      "sky_subscription_key": {
        "type": "api_key",
        "label": "SKY API subscription key",
        "generateUrl": "https://developer.blackbaud.com/subscriptions",
        "setup": "Create a [SKY Developer account](https://developer.blackbaud.com/signup), then go to [My subscriptions](https://developer.blackbaud.com/subscriptions), subscribe to either **Standard APIs** or **Payments API**, accept the terms, and use the subscription key shown there. The docs say you include it in the `Bb-Api-Subscription-Key` header on every request.",
        "acquisition": "manual"
      },
      "sky_oauth_app": {
        "type": "oauth2",
        "label": "SKY OAuth application credentials",
        "generateUrl": "https://developer.blackbaud.com/apps",
        "setup": "Sign up for a [SKY Developer account](https://developer.blackbaud.com/signup), then open [My applications](https://developer.blackbaud.com/apps) and create an application. Add your redirect URI(s) in the app details. Blackbaud says creating an application produces the credentials used for OAuth 2.0 authorization; use those app credentials with the authorization code flow against `https://app.blackbaud.com/oauth/authorize` and `https://oauth2.sky.blackbaud.com/token`. Public apps use PKCE; confidential apps also use the app secret.",
        "acquisition": "manual"
      }
    },
