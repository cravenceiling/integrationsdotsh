      "gitlab_pat": {
        "type": "api_key",
        "label": "GitLab personal access token",
        "generateUrl": "https://gitlab.com/-/user_settings/personal_access_tokens",
        "setup": "Create a personal access token in [your personal access tokens settings](https://gitlab.com/-/user_settings/personal_access_tokens). Choose the minimum scopes you need; `read_api` is sufficient for GraphQL queries, while `api` is required for writes and mutations. Many GitLab APIs accept this token in the `PRIVATE-TOKEN` header or as `Authorization: Bearer <token>`.",
        "acquisition": "manual"
      },
      "gitlab_project_token": {
        "type": "api_key",
        "label": "GitLab project access token",
        "generateUrl": "https://gitlab.com/-/profile/personal_access_tokens",
