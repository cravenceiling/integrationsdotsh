      },
      "cbi_api_bearer": {
        "type": "bearer",
        "label": "CB Insights API bearer access token",
        "setup": "First obtain CB Insights API credentials (`clientId` and `clientSecret`) from the [Developer Portal signup form](https://api-docs.cbinsights.com/portal/signup) or through your CB Insights Customer Success Manager as described in the [API reference](https://api-docs.cbinsights.com/portal/docs/api). Then exchange them by `POST`ing JSON to `https://api.cbinsights.com/v2/authorize` as shown in the [Quick Start Guide](https://api-docs.cbinsights.com/portal/docs/quick-start). The response returns a bearer `token` and `expiresIn`.",
