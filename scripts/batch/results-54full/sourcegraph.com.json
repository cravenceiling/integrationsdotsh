      },
      "sg_oauth_app": {
        "type": "oauth2",
        "label": "Sourcegraph OAuth app token",
        "generateUrl": "https://sourcegraph.com/docs/admin/oauth-apps",
        "setup": "A site admin creates an OAuth app in **Site admin > OAuth clients** as described in [OAuth Apps](https://sourcegraph.com/docs/admin/oauth-apps). Choose the needed scopes for your integration, then complete the user OAuth flow against your Sourcegraph instance. Use `user:all` for GraphQL and streaming search, `externalapi:read`/`externalapi:write` for the supported external API, and `mcp` for MCP.",
        "acquisition": "manual"
      },
      "sg_m2m_client": {
        "type": "oauth2_cc",
        "label": "Sourcegraph service-account M2M OAuth client",
        "generateUrl": "https://sourcegraph.com/docs/admin/service-accounts",
        "setup": "Create a service account, then open that account's **Access tokens > M2M credentials** and click **Create M2M credential** as documented in [service accounts](https://sourcegraph.com/docs/admin/service-accounts). Save the generated `client_id` and `client_secret`, then exchange them for a short-lived bearer token with the Sourcegraph OAuth token endpoint. Select scopes appropriate to the target API.",
        "acquisition": "manual"
      },
