    "summary": "Dremio exposes two REST APIs, a Developer CLI, and an MCP server; all require authentication via Dremio bearer tokens, PATs, or OAuth client credentials depending on the surface.",
    "credentials": {
      "dremio_access_token": {
        "type": "bearer",
        "label": "Dremio access token",
        "setup": "Use this token in `Authorization: Bearer <token>` for Dremio REST APIs. Dremio issues three kinds of access tokens: OAuth access tokens, personal access tokens (PATs), and authentication tokens. The easiest path is usually a PAT from the Dremio console ([Personal Access Tokens](https://docs.dremio.com/current/security/authentication/personal-access-tokens/)) or via the PAT API ([PAT API](https://docs.dremio.com/current/reference/api/personal-access-token/)); OAuth access tokens can also be minted from the [OAuth Token API](https://docs.dremio.com/current/reference/api/oauth-token/).",
        "acquisition": "manual"
      },
      "dremio_pat": {
        "type": "api_key",
        "label": "Dremio personal access token (PAT)",
        "setup": "Create a PAT in the Dremio console under [Personal Access Tokens](https://docs.dremio.com/current/security/authentication/personal-access-tokens/) or with the [PAT API](https://docs.dremio.com/current/reference/api/personal-access-token/). Dremio notes PATs can also be created from the API for the current user; use the resulting token as a bearer credential.",
        "acquisition": "manual"
      },
      "dremio_oauth_client": {
        "type": "oauth2_cc",
        "label": "Dremio OAuth client credentials",
        "setup": "Create a service user / OAuth application in Dremio, then use the client ID and client secret to obtain an OAuth access token from the OAuth token endpoint. For Dremio Cloud, the docs say to create a native OAuth application in the console under Organization → OAuth Applications, then use the client ID with the MCP or API flow. For machine-to-machine, Dremio documents `grant_type=client_credentials` with `scope=dremio.all`.",
        "acquisition": "manual"
      },
      "dremio_username_password": {
        "type": "basic",
        "label": "Dremio username and password",
        "setup": "Use your Dremio username and password to mint a short-lived authentication token through the legacy v2 login flow documented by Dremio ([Authentication](https://docs.dremio.com/current/security/authentication/) and [API Reference](https://docs.dremio.com/current/reference/api/)). This is mainly a bootstrap credential for obtaining a bearer token, not something you send to the REST API directly.",
        "acquisition": "manual"
      }
    },
