      "platform_api_token": {
        "type": "api_key",
        "label": "Turso Platform API token",
        "generateUrl": "https://docs.turso.tech/api-reference/tokens/create",
        "setup": "Create a Platform API token with the Turso CLI after logging in: `turso auth login` or `turso auth signup`, then mint a token such as `turso auth api-tokens mint my-token --org my-org`. The API docs also show token creation via the [Create API Token endpoint](https://docs.turso.tech/api-reference/tokens/create). See [API authentication](https://docs.turso.tech/api-reference/authentication) for scoping guidance.",
        "acquisition": "manual"
      },
      "db_auth_token": {
        "type": "jwt",
        "label": "Turso database auth token",
        "setup": "Create a database or group token with the Turso CLI, for example `turso db tokens create <database-name>` or `turso group tokens create <group-name>`. You can add flags like `--read-only`, `--permissions`, and `--expiration`. The docs note you can also create these via the [Platform API](https://docs.turso.tech/api-reference/databases/create-token). See [Platform Tokens](https://docs.turso.tech/sdk/authorization/tokens) and [SDK authentication](https://docs.turso.tech/sdk/authentication).",
        "acquisition": "manual"
      },
      "cli_login": {
        "type": "oauth2",
        "label": "Turso CLI login session",
        "generateUrl": "https://docs.turso.tech/cli/authentication",
        "setup": "Install the CLI from [CLI installation](https://docs.turso.tech/cli/installation), then run `turso auth login` (or `turso auth signup`). The CLI opens a browser for GitHub-based login; in remote/WSL/CI-style environments you can use `turso auth login --headless`. The docs say the CLI uses an access token and requires reauthentication after one week.",
        "acquisition": "manual"
      },
      "mcp_oauth": {
        "type": "oauth2",
        "label": "Turso MCP OAuth grant",
        "generateUrl": "https://docs.turso.tech/integrations/mcp",
        "setup": "Point an MCP client at `https://mcp.turso.ai/mcp` and start authentication from the client (for example `codex mcp login turso`, or in Claude choose **Authenticate** after adding the connector). Approval happens in the browser on Turso, where you choose an organization and optionally scope access to a group and permissions. The docs state there is no API token to copy or paste.",
        "acquisition": "manual"
      }
