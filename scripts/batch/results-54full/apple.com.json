      "appstoreconnect_api_key": {
        "type": "compound",
        "label": "App Store Connect API key + issuer ID used to sign JWT bearer tokens",
        "generateUrl": "https://developer.apple.com/help/app-store-connect/get-started/app-store-connect-api/",
        "setup": "In [App Store Connect API get started](https://developer.apple.com/help/app-store-connect/get-started/app-store-connect-api/) and [Creating API Keys for App Store Connect API](https://developer.apple.com/documentation/appstoreconnectapi/creating-api-keys-for-app-store-connect-api), Apple directs you to create an App Store Connect API key in App Store Connect, download the private key file, and use the key ID plus your issuer ID to sign a JWT for API requests. The resulting JWT is sent as `Authorization: Bearer ...`.",
        "acquisition": "manual"
      },
      "apple_music_developer_token": {
        "type": "jwt",
        "label": "Apple Music developer token",
        "generateUrl": "https://developer.apple.com/documentation/applemusicapi/generating-developer-tokens",
        "setup": "Follow [Generating Developer Tokens](https://developer.apple.com/documentation/applemusicapi/generating-developer-tokens). Apple says a developer token is a signed token used to authenticate a developer in Apple Music requests. You create and sign this token from your Apple Developer credentials and send it in the `Authorization` header as a bearer token.",
        "acquisition": "manual"
      },
      "apple_music_user_token": {
        "type": "bearer",
        "label": "Apple Music user token",
        "generateUrl": "https://developer.apple.com/documentation/applemusicapi/user-authentication-for-musickit",
        "setup": "Follow [User Authentication for MusicKit](https://developer.apple.com/documentation/applemusicapi/user-authentication-for-musickit) to obtain a Music User Token after the user authorizes access through MusicKit. Apple’s Apple Music API docs describe this token as the credential for requests involving a user’s library or account-specific data, sent in the `Music-User-Token` header together with a developer token.",
        "acquisition": "manual"
      }
    },
