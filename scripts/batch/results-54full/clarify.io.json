      "clarify_basic": {
        "type": "basic",
        "label": "Clarify Basic Auth username and password",
        "generateUrl": "https://docs.clarify.io/developers/quickstart/create-integration",
        "setup": "Create an integration from Clarify's UI as shown in [Create an integration](https://docs.clarify.io/developers/quickstart/create-integration), then create **Basic Auth** credentials for that integration. Clarify shows a username and password once; save them securely because they cannot be downloaded again. The same Basic Auth credentials are used for the HTTP API and the MQTT broker.",
        "acquisition": "manual"
      },
      "clarify_oauth_cc": {
        "type": "oauth2_cc",
        "label": "Clarify OAuth 2.0 client-credentials file",
        "generateUrl": "https://docs.clarify.io/developers/quickstart/create-integration",
        "setup": "Create an integration from Clarify's UI as shown in [Create an integration](https://docs.clarify.io/developers/quickstart/create-integration), then create **OAuth 2.0** credentials for that integration. Download and securely store the `clarify-credentials.json` file immediately; Clarify says it cannot be downloaded again after the window is closed. Use the `clientId` and `clientSecret` from that file to request a bearer token from `https://api.clarify.io/v1/oauth/token` with `grant_type=client_credentials` and `audience=https://api.clarify.io/v1/`, as documented in [Transport protocol (HTTP)](https://docs.clarify.io/api/1.1/protocol/http).",
        "acquisition": "manual"
