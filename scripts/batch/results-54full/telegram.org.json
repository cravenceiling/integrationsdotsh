    "summary": "Telegram exposes three developer-facing API surfaces on telegram.org: the HTTP Telegram Bot API, the HTTP Telegram Gateway API, and the Telegram API/MTProto platform for custom clients; it also documents Telegram Login/OIDC credentials but not as a standalone API surface here.",
    "description": "Telegram is a cloud messaging platform with consumer apps, bots, and developer tools for building custom Telegram clients and business verification flows. It also provides website and app login capabilities tied to Telegram accounts.",
    "credentials": {
      "telegram_bot_token": {
        "type": "bearer",
        "label": "Telegram bot token",
        "generateUrl": "https://t.me/botfather",
        "setup": "Create a bot with [@BotFather](https://t.me/botfather) as described in [Bots: An introduction for developers](https://core.telegram.org/bots#how-do-i-create-a-bot). BotFather issues the bot token used to call the Bot API. Keep the token secret.",
        "acquisition": "manual"
      },
      "telegram_api_app": {
        "type": "compound",
        "label": "Telegram API app credentials (`api_id` + `api_hash`)",
        "generateUrl": "https://my.telegram.org/apps",
        "setup": "Sign in at [my.telegram.org](https://my.telegram.org), open [API development tools](https://my.telegram.org/apps), and create an application as described in [Creating your Telegram Application](https://core.telegram.org/api/obtaining_api_id). Telegram will show your `api_id` and `api_hash`. These are required when authorizing a client against the Telegram API/TDLib.",
        "acquisition": "manual"
      },
      "telegram_gateway_token": {
        "type": "bearer",
        "label": "Telegram Gateway access token",
        "setup": "Open your Telegram Gateway account settings and create an access token, as required by the [Gateway API authorization](https://core.telegram.org/gateway/api#authorization). The overview page links to the [Gateway API](https://core.telegram.org/gateway/api) and testing guide at [Telegram Gateway](https://core.telegram.org/gateway).",
        "acquisition": "manual"
      },
      "telegram_login_oidc_client": {
        "type": "oauth2",
        "label": "Telegram Login OIDC client (`client_id` + `client_secret`)",
        "generateUrl": "https://t.me/botfather?startapp",
        "setup": "Set up a Telegram bot, then open [@BotFather](https://t.me/botfather?startapp) and go to **Bot Settings > Web Login** as described in [Log In With Telegram](https://core.telegram.org/widgets/login). Register your allowed URLs there; BotFather shows your `client_id` and `client_secret` for the OpenID Connect client.",
        "acquisition": "manual"
      }
