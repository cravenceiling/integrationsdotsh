    "summary": "SourceHut exposes a multi-service GraphQL API surface (one `/query` endpoint per service host such as `meta.sr.ht`, `git.sr.ht`, `builds.sr.ht`, `pages.sr.ht`, etc.) authenticated with SourceHut personal access tokens or OAuth 2.0 bearer tokens, plus the `hut` CLI for command-line access.",
    "description": "SourceHut is a hosted suite of software development tools including Git and Mercurial hosting, continuous integration, mailing lists, ticket tracking, static site hosting, and account management services. It operates as a set of related `*.sr.ht` services under the SourceHut platform.",
    "credentials": {
      "srht_pat": {
        "type": "bearer",
        "label": "SourceHut personal access token",
        "generateUrl": "https://meta.sr.ht/oauth2",
        "setup": "In [meta.sr.ht OAuth settings](https://meta.sr.ht/oauth2), create a personal access token with the minimum required scopes for the services you will call. SourceHut documents scope strings in [OAuth 2.0 via meta.sr.ht](https://man.sr.ht/meta.sr.ht/oauth.md) and per-resolver requirements in each service's GraphQL schema docs on [docs.sourcehut.org](https://docs.sourcehut.org/).",
        "acquisition": "manual"
      },
      "srht_oauth_client": {
        "type": "oauth2",
        "label": "SourceHut OAuth 2.0 client (client ID + client secret)",
        "generateUrl": "https://meta.sr.ht/oauth2",
        "setup": "Register an OAuth 2.0 client at [meta.sr.ht OAuth settings](https://meta.sr.ht/oauth2). SourceHut issues a client ID and client secret there. Then send the user through the authorization flow described in [OAuth 2.0 via meta.sr.ht](https://man.sr.ht/meta.sr.ht/oauth.md): authorize at `https://meta.sr.ht/oauth2/authorize` with an explicit `scope`, then exchange the code at `https://meta.sr.ht/oauth2/access-token`. SourceHut supports confidential clients only; the registered redirect URI is fixed and `redirect_uri` must not be sent per their docs.",
        "acquisition": "manual"
      },
      "hut_cli_login": {
        "type": "oauth2",
        "label": "hut CLI login session",
        "setup": "Install the `hut` CLI, then authenticate with its login flow. SourceHut's docs describe `hut` as the CLI tool for SourceHut and note it can run GraphQL queries and manage SourceHut services from the command line in the [SourceHut homepage](https://sourcehut.org/) and [GraphQL on SourceHut](https://man.sr.ht/graphql.md).",
        "acquisition": "manual"
      }
