    "summary": "Unleash exposes four tenant-hosted HTTP APIs (Client, Frontend, Admin, and Edge-compatible endpoints), plus a remote MCP server and an npm-distributed MCP CLI for AI agents.",
    "description": "Unleash is a feature management platform for creating, rolling out, and monitoring feature flags across applications. It is available as open source and hosted offerings, with support for SDKs, automation, and enterprise controls such as RBAC and service accounts.",
    "credentials": {
      "unleash_backend_token": {
        "type": "api_key",
        "label": "Backend API token",
        "setup": "In your Unleash instance, go to **Admin settings → Access control → API access** and create a **backend token**. Backend tokens are scoped to one or more projects and a single environment, and are intended for the Client API and Unleash Edge client endpoints. See [API tokens and client keys](https://docs.getunleash.io/concepts/api-tokens-and-client-keys) and [API overview](https://docs.getunleash.io/api)."
      },
      "unleash_frontend_token": {
        "type": "api_key",
        "label": "Frontend API token",
        "setup": "In your Unleash instance, go to **Admin settings → Access control → API access** and create a **frontend token**. Frontend tokens are scoped to one or more projects and a single environment, are safe to expose client-side, and are used with the Frontend API or Unleash Edge frontend endpoints. See [API tokens and client keys](https://docs.getunleash.io/concepts/api-tokens-and-client-keys) and [API overview](https://docs.getunleash.io/api)."
      },
      "unleash_pat": {
        "type": "bearer",
        "label": "Personal access token",
        "setup": "Log in to your Unleash instance, open **Profile → Personal Access Tokens**, and create a new token. Unleash recommends PATs for testing, debugging, temporary automation access, and the local MCP server. See [API tokens and client keys](https://docs.getunleash.io/concepts/api-tokens-and-client-keys) and the MCP setup in [Unleash MCP Server](https://docs.getunleash.io/integrate/mcp)."
      },
      "unleash_service_account_token": {
        "type": "bearer",
        "label": "Service account token",
        "setup": "Create a service account in your Unleash instance and generate its token from the service account configuration in the Admin UI. Service account tokens are intended for integrations and automation tools with specific permissions. See [Service accounts](https://docs.getunleash.io/concepts/service-accounts) and [API tokens and client keys](https://docs.getunleash.io/concepts/api-tokens-and-client-keys)."
      }
