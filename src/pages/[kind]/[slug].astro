---
import Base from "~/layouts/Base.astro";
import Breadcrumb from "~/components/Breadcrumb.astro";
import Markdown from "~/components/Markdown.tsx";
import { byKind, kindLabel, domainById } from "~/lib/data.ts";
import type { Kind } from "~/lib/types.ts";

export function getStaticPaths() {
  const kinds = ["mcp", "openapi", "graphql", "cli"] satisfies Kind[];
  return kinds.flatMap((kind) =>
    byKind[kind].map((item) => ({
      params: { kind, slug: item.slug },
      props: { item },
    })),
  );
}

const { item } = Astro.props;
const domain = domainById.get(item.id) ?? item.slug;
let connectCmd: string | null = null;
let connectLabel = "Connect";
if (item.kind === "mcp" && item.mcp?.remoteUrl) {
  connectCmd = `claude mcp add --transport http ${item.slug} ${item.mcp.remoteUrl}`;
} else if (item.kind === "cli" && item.cli?.install) {
  connectCmd = item.cli.install;
  connectLabel = "Install";
}

const title = `${item.name} — ${kindLabel[item.kind]}`;
const description = (item.description || `${item.name} ${kindLabel[item.kind]} details for AI agents.`).slice(0, 160);
---

<Base title={title} description={description} path={`/${item.kind}/${item.slug}/`}>
  <div class="container">
    <article data-pagefind-body>
      <Breadcrumb
        segments={[
          { label: "registry", href: "/" },
          { label: domain, href: `/d/${encodeURIComponent(domain)}/` },
          { label: item.kind, href: `/?kind=${item.kind}` },
        ]}
      />

      <header class="head">
        <div class="favicon">
          {item.icon
            ? <img src={item.icon} width="22" height="22" alt="" onerror="this.remove()" />
            : <span>{item.name[0]}</span>}
        </div>
        <div class="head-body">
          <h1>{item.name}</h1>
          <p class="meta" data-pagefind-filter={`kind:${item.kind}`}>
            {kindLabel[item.kind]}
          </p>
        </div>
      </header>

      {item.description && <Markdown text={item.description} className="desc" />}

      {connectCmd && (
        <section>
          <div class="sec-header"><span class="sec-label">{connectLabel}</span></div>
          <pre class="code-block">{connectCmd}</pre>
        </section>
      )}

      <section>
        <div class="sec-header"><span class="sec-label">Details</span></div>
        <dl class="kv">
          {item.cli && (
            <>
              <dt>Domain</dt>
              <dd><a href={`/d/${encodeURIComponent(item.cli.domain)}/`}>{item.cli.domain}</a></dd>
              {item.cli.docs && (
                <>
                  <dt>Docs</dt>
                  <dd><a href={item.cli.docs} target="_blank" rel="noopener">{item.cli.docs}</a></dd>
                </>
              )}
              {item.cli.repo && (
                <>
                  <dt>Repo</dt>
                  <dd><a href={item.cli.repo} target="_blank" rel="noopener">{item.cli.repo}</a></dd>
                </>
              )}
            </>
          )}
          {item.url && !item.cli && (
            <>
              <dt>Homepage</dt>
              <dd><a href={item.url} target="_blank" rel="noopener">{item.url}</a></dd>
            </>
          )}
          {item.mcp?.remoteUrl && (
            <>
              <dt>Endpoint</dt>
              <dd><code>{item.mcp.remoteUrl}</code></dd>
            </>
          )}
          {item.mcp?.transport && (
            <>
              <dt>Transport</dt>
              <dd>{item.mcp.transport}</dd>
            </>
          )}
          {item.mcp?.authTypes && item.mcp.authTypes.length > 0 && (
            <>
              <dt>Auth</dt>
              <dd>{item.mcp.authTypes.join(", ").toLowerCase()}</dd>
            </>
          )}
          {item.openapi && (
            <>
              <dt>Provider</dt>
              <dd>{item.openapi.provider}{item.openapi.service ? ` / ${item.openapi.service}` : ""}</dd>
              <dt>OpenAPI</dt>
              <dd>{item.openapi.openapiVer}</dd>
              {item.openapi.swaggerUrl && (
                <>
                  <dt>Spec</dt>
                  <dd><a href={item.openapi.swaggerUrl} target="_blank" rel="noopener">json</a>{item.openapi.swaggerYamlUrl && <> · <a href={item.openapi.swaggerYamlUrl} target="_blank" rel="noopener">yaml</a></>}</dd>
                </>
              )}
            </>
          )}
          {item.graphql && (
            <>
              <dt>Endpoint</dt>
              <dd><code>{item.graphql.endpoint}</code></dd>
              <dt>Auth</dt>
              <dd>{item.graphql.hasSecurity ? "required" : "none"}</dd>
              {item.graphql.docs.length > 0 && (
                <>
                  <dt>Docs</dt>
                  <dd>
                    {item.graphql.docs.map((d, i) => (
                      <span>{i > 0 && " · "}<a href={d.url} target="_blank" rel="noopener">{d.description ?? d.url}</a></span>
                    ))}
                  </dd>
                </>
              )}
            </>
          )}
        </dl>
      </section>

    </article>
  </div>
</Base>

<style>
  .head { padding: 24px 0 0; display: flex; align-items: flex-start; gap: 16px; max-width: 760px; }
  .favicon {
    width: 40px; height: 40px;
    border: 1px solid var(--gray-100); border-radius: 8px;
    display: grid; place-items: center;
    background: var(--white); flex-shrink: 0; margin-top: 2px;
    font-weight: 600; color: var(--gray-400);
  }
  .favicon img { border-radius: 4px; }
  h1 { font-size: 28px; font-weight: 600; letter-spacing: -0.03em; line-height: 1.2; margin: 0; }
  .meta { margin: 6px 0 0; font-family: var(--font-mono); font-size: 12px; color: var(--gray-400); }

  .upsell {
    margin: 26px 0 0;
    padding: 12px 16px;
    border: 1px solid var(--gray-100);
    border-radius: 6px;
    font-size: 14px;
    color: var(--gray-500);
    max-width: 760px;
  }
  .upsell a { color: var(--gray-1000); text-decoration: underline; text-underline-offset: 2px; }

  :global(.desc) { color: var(--gray-500); font-size: 14.5px; max-width: 70ch; margin-top: 24px; }

  section { margin-top: 48px; max-width: 760px; }
  section :global(.code-block) { margin-top: 16px; }

  dl.kv {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 10px 28px;
    margin: 18px 0 0;
    font-size: 14px;
  }
  dl.kv dt { color: var(--gray-400); font-family: var(--font-mono); font-size: 12.5px; }
  dl.kv dd { margin: 0; min-width: 0; word-break: break-all; }
  dl.kv a { text-decoration: underline; text-underline-offset: 2px; }
  dl.kv a:hover { color: var(--gray-500); }
  dl.kv code { background: var(--gray-50); padding: 1px 6px; border-radius: 3px; font-size: 12.5px; }

</style>
