---
// The one shell every page renders through — prerendered catalog pages and
// worker-SSR'd discovery pages alike, so there is nothing to drift.
import "~/styles/global.css";
import Nav from "~/components/Nav.astro";
import Footer from "~/components/Footer.astro";
import { ANALYTICS_JS } from "~/lib/analytics.ts";

interface Props {
  title: string;
  description?: string;
  /** Canonical path, e.g. "/todoist/". */
  path?: string;
}
const {
  title,
  description = "Services your agent can reach — official APIs, GraphQL endpoints, and MCP servers, with structured credential facts.",
  path,
} = Astro.props;
const canonical = path ? new URL(path, Astro.site).href : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta name="twitter:card" content="summary" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/svg+xml" href="/favicon-light.svg" media="(prefers-color-scheme: dark)" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600&family=Geist+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <script is:inline set:html={ANALYTICS_JS} />
  </head>
  <body>
    <div class="frame-guides"></div>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
