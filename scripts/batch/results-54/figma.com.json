    "summary": "Mapped Figma’s public developer integration surface: 2 HTTP APIs (REST with OpenAPI, plus SCIM), 1 MCP server, and 1 CLI; all require Figma-issued credentials.",
    "credentials": {
      "figma_oauth_app": {
        "type": "oauth2",
        "label": "Figma OAuth app",
        "generateUrl": "https://www.figma.com/developers/apps",
        "setup": "Go to [My Apps](https://www.figma.com/developers/apps), click **Create a new app**, choose a team or organization, then copy the **Client ID** and **Client Secret** when the app is created. Finish the app configuration in [OAuth apps](https://developers.figma.com/docs/rest-api/oauth-apps/), including redirect/callback settings and scopes, before using it for user authorization and token exchange."
      },
      "figma_pat": {
        "type": "api_key",
        "label": "Figma personal access token",
        "generateUrl": "https://developers.figma.com/docs/rest-api/personal-access-tokens/",
        "setup": "Sign in to Figma, open **Settings** from the file browser account menu, go to the **Security** tab, and in **Personal access tokens** click **Generate new token**. Choose expiration and scopes, then copy the token when shown. Figma documents this flow in [Personal access tokens](https://developers.figma.com/docs/rest-api/personal-access-tokens/)."
      },
      "figma_plan_token": {
        "type": "bearer",
        "label": "Figma plan access token",
        "generateUrl": "https://developers.figma.com/docs/rest-api/plan-access-tokens/",
        "setup": "Have an organization or enterprise admin create a plan access token from Figma admin controls as described in [Authentication](https://developers.figma.com/docs/rest-api/authentication/) and the [Plan access tokens](https://developers.figma.com/docs/rest-api/plan-access-tokens/) guide. Plan access tokens are organization-level tokens for automation and are available on Organization and Enterprise plans."
      },
      "figma_scim_token": {
        "type": "bearer",
        "label": "Figma SCIM API token",
        "generateUrl": "https://developers.figma.com/docs/rest-api/scim/",
        "setup": "As an organization administrator, open Figma **Admin Settings**, go to **Login and Provisioning** → **SCIM Provisioning**, click **Generate Token**, and copy the token when shown. From **Login and Provisioning** → **SAML SSO**, also copy the **Tenant ID**, which is needed to build the SCIM base URL. See [SCIM API Reference](https://developers.figma.com/docs/rest-api/scim/)."
      }
    },
