    "summary": "Gravitee exposes HTTP management APIs for API Management and Access Management, an Access Management automation API, and a Node-based APIM MCP server CLI; all documented surfaces require authentication.",
    "description": "Gravitee provides API management and access management software for publishing, securing, governing, and automating APIs and identity resources. Its products include APIM for managing API gateways and portals, and AM for identity, OAuth/OIDC, and security-domain management.",
    "credentials": {
      "apim_basic": {
        "type": "basic",
        "label": "APIM management user credentials",
        "setup": "Use a Gravitee APIM management user account. In self-hosted installs this is created in the APIM console or identity provider configured for management access; the APIM Management API reference shows the API uses HTTP Basic auth and the APIM console lets admins create service accounts and personal tokens for delegated access. Start from the [Management API Reference](https://documentation.gravitee.io/apim/management-api-reference) and your APIM console/admin setup for a user with the needed permissions.",
        "acquisition": "manual"
      },
      "apim_personal_token": {
        "type": "bearer",
        "label": "APIM personal access token",
        "setup": "Sign in to your APIM Console, go to **Organization → Users**, open your user or service account, then under **Tokens** click **+ Generate a personal token** and copy the token. The APIM MCP documentation documents this flow for a service account. See [Expose APIM as an MCP Server](https://documentation.gravitee.io/apim/4.9-expose-apim-as-an-mcp-server).",
        "acquisition": "manual"
      },
      "am_mgmt_basic": {
        "type": "basic",
        "label": "AM management user credentials",
        "setup": "Use an Access Management administrator or management user account. The AM API reference shows you obtain a management API bearer token by calling `/management/auth/token` with HTTP Basic auth using your management username and password. See [AM API Reference](https://documentation.gravitee.io/am/reference/am-api-reference).",
        "acquisition": "manual"
      },
      "am_mgmt_token": {
        "type": "bearer",
        "label": "AM Management API bearer token",
        "setup": "Call the AM token endpoint `POST /management/auth/token` with your AM management user credentials via HTTP Basic auth to receive an `access_token`, then use that bearer token in `Authorization: Bearer ...`. See [AM API Reference](https://documentation.gravitee.io/am/reference/am-api-reference).",
        "acquisition": "manual"
      }
    },
