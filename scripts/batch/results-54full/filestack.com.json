    "summary": "Filestack exposes four documented HTTP integration surfaces: the File API, Processing API, Video/Audio Processing API, Workflows API, and a separate Management API; no public GraphQL API, MCP server, or CLI was found.",
    "description": "Filestack provides file upload, storage, CDN delivery, transformation, and workflow automation services for application developers. It also offers a management layer for configuring Filestack applications and related settings.",
    "credentials": {
      "filestack_api_key": {
        "type": "api_key",
        "label": "Filestack API key",
        "generateUrl": "https://dev.filestack.com/",
        "setup": "Sign in to the [Filestack Developer Portal](https://dev.filestack.com/). Create or open an application there and copy its API key. The docs' [Quick Start](https://www.filestack.com/docs/getting-started/quick-start/) and [File API](https://www.filestack.com/docs/api/file/) examples use this key as `key` in API requests or as the path segment in CDN/processing URLs."
      },
      "filestack_app_secret": {
        "type": "bearer",
        "label": "Filestack app secret / security-signing secret",
        "generateUrl": "https://dev.filestack.com/",
        "setup": "Sign in to the [Filestack Developer Portal](https://dev.filestack.com/) and open your application settings. Filestack generates a secret for each application; the [Security Policies](https://www.filestack.com/docs/security/policies/) page says this secret is used to sign Base64URL JSON policies with HMAC-SHA256. Use your backend to generate short-lived `policy` and `signature` values from that secret; those signed values are then sent to Filestack APIs. The [File API](https://www.filestack.com/docs/api/file/) also documents using the app secret directly as HTTP Basic password with username `app` for certain file operations."
      },
      "filestack_mgmt_client": {
        "type": "basic",
        "label": "Filestack Management API client ID and secret key",
        "generateUrl": "https://dev.filestack.com/",
        "setup": "Sign in to the [Filestack Developer Portal](https://dev.filestack.com/) and create or open an application used with the Management API. The [Management API](https://www.filestack.com/docs/api/management/) authenticates `POST /auth` with HTTP Basic auth using `<client_id>:<secret_key>`, then returns a JWT for subsequent requests."
      },
      "filestack_mgmt_jwt": {
        "type": "jwt",
        "label": "Filestack Management API JWT",
        "generateUrl": "https://www.filestack.com/docs/api/management/",
        "setup": "First obtain a Management API JWT by calling `POST /auth` at [Management API](https://www.filestack.com/docs/api/management/) with your Management API `client_id` and `secret_key` via HTTP Basic auth. The returned token is valid for 60 minutes and is then sent as `Authorization: Bearer <token>` on Management API requests."
      }
