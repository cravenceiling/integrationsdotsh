    "credentials": {
      "snyk_pat": {
        "type": "bearer",
        "label": "Snyk personal access token (PAT)",
        "generateUrl": "https://app.snyk.io/account/personal-access-tokens",
        "setup": "Log in to [Snyk account settings](https://app.snyk.io/account/personal-access-tokens), open the **Personal access tokens** tab, choose a name and expiry, then click **Generate new token**. Copy the token when shown; Snyk only reveals it once. PATs are documented at [Personal Access Tokens (PATs)](https://docs.snyk.io/developer-tools/snyk-api/authentication-for-api/personal-access-tokens-pats)."
      },
      "snyk_api_token": {
        "type": "api_key",
        "label": "Snyk API token / legacy API key",
        "generateUrl": "https://app.snyk.io/account",
        "setup": "Log in to [Snyk account settings](https://app.snyk.io/account), find the `key` field, click **Click to show**, and copy the token. To rotate it, use **Revoke & Regenerate** as described in [Authentication for API](https://docs.snyk.io/developer-tools/snyk-api/authentication-for-api)."
      },
      "snyk_service_account_token": {
        "type": "api_key",
        "label": "Snyk service account access token",
        "setup": "Create a Group- or Organization-level service account in the Snyk Web UI as described in [Service accounts](https://docs.snyk.io/platform-administration/service-accounts/service-accounts). Creating the service account generates its token; use that token for automation. Snyk recommends service accounts for CI/CD and API automation."
      },
      "snyk_oauth_client_secret": {
        "type": "oauth2_cc",
        "label": "Snyk OAuth 2.0 service account client credentials",
        "setup": "Create an OAuth 2.0 service account (Group or Organization level) via the Snyk API or Web UI as described in [Service accounts using OAuth 2.0](https://docs.snyk.io/platform-administration/service-accounts/service-accounts-using-oauth-2.0). On creation, Snyk returns a `client_id` and `client_secret`; the `client_secret` is only shown once. Exchange them at `POST https://api.snyk.io/oauth2/token` using the `client_credentials` grant to obtain an access token, then use that access token against Snyk APIs or the CLI."
      },
      "snyk_oauth_private_key_jwt": {
        "type": "two_step",
        "label": "Snyk OAuth 2.0 service account using Private Key JWT",
        "setup": "Create a Private Key JWT OAuth 2.0 service account as documented in [Service accounts using OAuth 2.0](https://docs.snyk.io/platform-administration/service-accounts/service-accounts-using-oauth-2.0). Generate and store the private key material during setup, sign a client assertion JWT, and exchange it at `POST https://api.snyk.io/oauth2/token` to obtain a short-lived OAuth access token for Snyk APIs or the CLI."
      },
      "snyk_oauth_access_token": {
        "type": "bearer",
        "label": "Snyk OAuth 2.0 access token",
        "setup": "Obtain this token either from the Snyk OAuth authorization-code flow for Snyk Apps described in [OAuth2 API](https://docs.snyk.io/developer-tools/snyk-api/oauth2-api), or from a Snyk OAuth 2.0 service account using `client_credentials` as described in [Service accounts using OAuth 2.0](https://docs.snyk.io/platform-administration/service-accounts/service-accounts-using-oauth-2.0). Use the returned `access_token` as a bearer token."
      }
    },
