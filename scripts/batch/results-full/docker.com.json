        "label": "Docker Hub account login token",
        "generateUrl": "https://hub.docker.com/",
        "setup": "Use your Docker Hub account credentials to mint a bearer token for Docker Hub API calls. The docs say most endpoints require authenticating with your Docker credentials, and the `Create an authentication token` route returns a bearer token. If your org enforces SSO, use a personal access token instead of a password. Start from your Docker Hub account at [hub.docker.com](https://hub.docker.com/) and create the token via the Docker Hub UI or by logging in through the API.",
        "acquisition": "manual"
      },
      "docker_pat": {
        "type": "bearer",
        "label": "Docker personal access token (PAT)",
        "generateUrl": "https://hub.docker.com/settings/security",
        "setup": "Create a Docker personal access token in your Docker account security settings. Docker recommends PATs as the more secure alternative to passwords, and they are required for some SSO-enforced organizations. Go to [Docker Hub security settings](https://hub.docker.com/settings/security) and create a new access token, then use it wherever Docker accepts a password or bearer-token login flow.",
        "acquisition": "manual"
      },
      "docker_oat": {
        "type": "bearer",
        "label": "Docker organization access token",
        "generateUrl": "https://hub.docker.com/settings/org-tokens",
        "setup": "Create an organization access token in Docker Hub for automation and CI/CD. The docs say these tokens are managed by organization owners and are intended for automated systems. Go to [organization settings](https://hub.docker.com/settings/org-tokens) in Docker Hub, create a new org token, and scope it to the required org resources and permissions.",
        "acquisition": "manual"
      }
