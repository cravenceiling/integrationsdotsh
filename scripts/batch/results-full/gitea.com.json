    "summary": "Gitea exposes an authenticated HTTP API and a Gitea MCP server; the API accepts token/basic auth plus SSH-key HTTP signatures, while MCP auth could not be determined from the public page.",
    "credentials": {
      "gitea_api_token": {
        "type": "api_key",
        "label": "Gitea personal access token",
        "generateUrl": "https://gitea.com/user/settings/applications",
        "setup": "Go to [User Settings → Applications](https://gitea.com/user/settings/applications) (or `https://gitea.com/user/settings/applications`) and open **Manage Access Tokens**. Create a token with the minimum scopes you need; Gitea notes the token is shown only once. If you need to mint one by API, use `POST /api/v1/users/:name/tokens` with your username and password, but the UI is the easiest path.",
        "acquisition": "manual"
      },
      "gitea_ssh_sig": {
        "type": "signature",
        "label": "Gitea HTTP signature via SSH key/certificate",
        "generateUrl": "https://gitea.com/user/settings/keys",
        "setup": "Register your SSH public key or SSH certificate on your Gitea account under the SSH keys settings, then sign API requests with the matching private key using the draft-cavage HTTP Signatures flow. SSH certificates additionally require the `x-ssh-certificate` header. This is the documented alternative to token auth for API requests.",
        "acquisition": "manual"
      },
      "gitea_basic_password": {
        "type": "basic",
        "label": "Gitea username/password for token minting",
        "generateUrl": "https://gitea.com/user/login",
        "setup": "Use your normal Gitea username and password when calling the special token-minting endpoint `POST /api/v1/users/:name/tokens`. The docs state this endpoint requires `BasicAuth` with a password; it is for creating an API token, not for routine API use.",
        "acquisition": "manual"
      }
