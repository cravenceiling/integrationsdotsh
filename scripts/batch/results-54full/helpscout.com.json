    "summary": "Help Scout exposes HTTP APIs for Docs, Inbox, Chat, and Apps/Beacon integrations plus Beacon mobile SDKs; recorded auth is Docs API key over Basic auth, OAuth Bearer token for Chat, app secret for signed app callbacks, and a Beacon secure-mode secret, while Inbox and some Beacon surfaces remain auth-undetermined.",
    "credentials": {
      "docs_api_key": {
        "type": "api_key",
        "label": "Docs API key",
        "generateUrl": "https://developer.helpscout.com/docs-api/",
        "setup": "In your Help Scout account, click the profile/person icon, open **Your Profile**, then go to **Authentication** → **API Keys** to generate, view, or regenerate your Docs API key. If you do not see an API key, an account owner or administrator must grant the **Docs: Create new, edit settings & Collections** permission first. See [Docs API Overview](https://developer.helpscout.com/docs-api/)."
      },
      "oauth_app": {
        "type": "oauth2",
        "label": "Help Scout OAuth app",
        "generateUrl": "https://developer.helpscout.com/apps/getting-started/",
        "setup": "Log in to Help Scout as an administrator or account owner, go to **Manage > Apps**, click **Create**, then **Create App**, and complete the form for your app. Use the app's credentials to obtain OAuth access tokens for Help Scout APIs. Help Scout's app setup flow is described in [Apps Getting Started](https://developer.helpscout.com/apps/getting-started/), and API requests shown in the Chat API docs use `Authorization: Bearer oauth_token` in [Chat API endpoint docs](https://developer.helpscout.com/chat/endpoints/get/)."
      },
      "app_secret": {
        "type": "api_key",
        "label": "Help Scout App secret key",
        "generateUrl": "https://developer.helpscout.com/apps/getting-started/",
        "setup": "Create a Help Scout App in **Manage > Apps** → **Create** → **Create App**, then set the **Secret Key** field in the app form. Help Scout includes an `X-HelpScout-Signature` query parameter on requests to your app callback URLs, and you use this shared secret to verify the signature as described in [Signature Validation](https://developer.helpscout.com/apps/guides/signature-validation/)."
      },
      "beacon_secret": {
        "type": "api_key",
        "label": "Beacon secure mode secret key",
        "generateUrl": "https://developer.helpscout.com/beacon-2/web/secure-mode/",
        "setup": "In Help Scout, go to **Manage → Beacon**, open the **Contact** tab, and enable **cross-device history**. Toggling this reveals the Beacon secure mode key; click **Save** to save the settings and key. Use this key to generate the HMAC signature passed with Beacon user identification in secure mode, as documented in [Beacon Secure Mode](https://developer.helpscout.com/beacon-2/web/secure-mode/)."
      }
    },
