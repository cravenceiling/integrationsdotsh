    "summary": "Craft exposes a documented HTTP API via per-connection endpoints plus a streamable HTTP MCP server at `https://mcp.craft.do/my/mcp`; both require user-granted access from a Craft workspace.",
    "description": "Craft is a document and note-taking workspace for writing, tasks, daily notes, collections, and collaboration across web and native apps. It lets users organize and share content, and offers API/MCP-based access to selected workspace content.",
    "credentials": {
      "craft_api_connection": {
        "type": "compound",
        "label": "Craft API connection credentials",
        "generateUrl": "https://craft-support.mintlify.app/en/integrate/api",
        "setup": "In Craft, create an API Connection from the Imagine tab. In the app, open **Imagine**, click **Add Your First API Connection**, choose a name, add the documents or daily notes it should expose, then copy the API endpoint and credentials shown there. You can later review and manage connections in **Craft Settings → API**. The Help Center's [Craft API](https://craft-support.mintlify.app/en/integrate/api) page describes this flow, and the [Codex CLI guide](https://www.craft.do/imagine/guide/api/codex_cli) shows that Craft displays an API URL for the connection. The docs do not publicly specify the exact credential format or header names.",
        "acquisition": "manual"
      },
      "craft_mcp_approval": {
        "type": "oauth2",
        "label": "Craft MCP workspace approval",
        "generateUrl": "https://www.craft.do/imagine/guide/mcp/mcp",
        "setup": "Connect an MCP client to `https://mcp.craft.do/my/mcp`. Craft opens a browser-based authorization page where you select the space to connect and click **Approve**. The [Craft MCP for Other MCP Clients guide](https://www.craft.do/imagine/guide/mcp/mcp) documents this approval flow. This is handled through the MCP client's OAuth flow rather than by manually minting a token in Craft.",
        "acquisition": "manual"
      }
