      },
      "ory_oauth2_client": {
        "type": "compound",
        "label": "Ory OAuth2 client credentials",
        "generateUrl": "https://console.ory.com/",
        "setup": "Create an OAuth2 client in Ory Network/Console or via the Ory CLI. For machine-to-machine access, use the client's `client_id` and `client_secret` with the client credentials grant to obtain access tokens. For browser auth, use the same client in an authorization code flow.",
        "acquisition": "manual"
      },
      "ory_docs_mcp": {
        "type": "bearer",
