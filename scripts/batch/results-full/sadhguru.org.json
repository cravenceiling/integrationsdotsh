      "global_prs_auth_token": {
        "type": "bearer",
        "label": "Global PRS auth token",
        "setup": "Obtain this from the Global PRS / Isha internal team that operates the registration API. The docs show API requests use an `Authorization: Bearer <token>` header, so ask for the system token used by your integration and store it securely.",
        "acquisition": "manual"
      },
      "global_prs_system_token": {
        "type": "api_key",
        "label": "Global PRS system token",
        "setup": "Obtain this from the Global PRS / Isha internal team that owns the integration. The API reference shows a separate required `x-system-token` header in addition to bearer auth, so request the system token used for your environment and keep it secret.",
        "acquisition": "manual"
      },
      "mymedic_oauth2": {
        "type": "oauth2",
        "label": "MyMedic OAuth 2.0 credentials",
        "setup": "Create or request the MyMedic integration credentials from the MyMedic side, then configure OAuth 2.0 for the integration. The Global PRS docs say to obtain MyMedic API credentials and set up OAuth2 with the needed scopes (`programs.read`, `appointments.write`).",
        "acquisition": "manual"
      },
      "iso_website_oauth2": {
        "type": "oauth2",
        "label": "ISO Website OAuth 2.0 credentials",
        "setup": "Obtain or create the ISO Website integration credentials from the ISO Website / Isha team, then configure OAuth 2.0 for program and registration APIs. The docs show the integration uses OAuth2 with `programs.read` and `programs.write` scopes.",
        "acquisition": "manual"
      }
    },
