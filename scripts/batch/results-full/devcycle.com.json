        "setup": "Use the DevCycle CLI `login sso` flow to open the browser-based DevCycle universal login, choose your organization, and store a short-lived access token locally. The CLI docs also mention `login again` to refresh the token without re-prompting for org selection.",
        "acquisition": "manual"
      },
      "dvc_client_creds_file": {
        "type": "compound",
        "label": "DevCycle CLI auth-file client credentials",
