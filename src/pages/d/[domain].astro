---
import Base from "~/layouts/Base.astro";
import { index, byId } from "~/lib/data.ts";
import type { IndexRecord } from "~/lib/data.ts";
import type { Kind } from "~/lib/types.ts";

// Group every enriched record by its registrable domain (the same key the
// homepage groups by: `domain`, else the slug). One page per domain.
export function getStaticPaths() {
  const groups = new Map<string, IndexRecord[]>();
  for (const r of index) {
    const d = r.domain || r.slug;
    if (!d) continue;
    (groups.get(d) ?? groups.set(d, []).get(d)!).push(r);
  }
  return [...groups.entries()].map(([domain, records]) => ({
    params: { domain },
    props: { domain, records },
  }));
}

const KIND_ORDER = ["mcp", "openapi", "graphql", "cli"] as const;
const SECTION_LABEL: Record<Kind, string> = {
  mcp: "MCP servers",
  openapi: "REST · OpenAPI",
  graphql: "GraphQL",
  cli: "CLI",
};
// Short labels for the header summary line.
const SHORT_LABEL: Record<Kind, string> = {
  mcp: "MCP",
  openapi: "REST",
  graphql: "GraphQL",
  cli: "CLI",
};

const { domain, records } = Astro.props;

// Sections in canonical format order, most-popular record first within each.
const sections = KIND_ORDER.map((kind) => ({
  kind,
  label: SECTION_LABEL[kind],
  items: records
    .filter((r) => r.kind === kind)
    .sort(
      (a, b) => (b.popularity ?? 0) - (a.popularity ?? 0) || a.name.localeCompare(b.name),
    ),
})).filter((s) => s.items.length > 0);

const icon = records.find((r) => r.icon)?.icon
  ?? `https://www.google.com/s2/favicons?domain=${encodeURIComponent(domain)}&sz=64`;

const formatList = sections.map((s) => SECTION_LABEL[s.kind].replace(" · ", "/")).join(", ");
const title = `${domain} — integrations`;
const description = `${records.length} integration${records.length === 1 ? "" : "s"} for ${domain} across ${formatList} — readable by you and your agent.`;

// Per-record meta hint shown on the right of each row. The slim index record
// lacks per-format detail, so join back to the full record via `byId`.
const metaFor = (r: IndexRecord): string => {
  const full = byId.get(r.id);
  if (r.kind === "mcp") {
    const n = full?.tools?.length ?? full?.mcp?.toolNames?.length ?? 0;
    return n ? `${n} tool${n === 1 ? "" : "s"}` : "mcp";
  }
  if (r.kind === "openapi") return full?.openapi?.version ? `v${full.openapi.version}` : "openapi";
  if (r.kind === "graphql") return full?.graphql?.hasSecurity ? "auth" : "graphql";
  if (r.kind === "cli") return "cli";
  return "";
};
---

<Base title={title} description={description} path={`/d/${domain}/`}>
  <div class="container">
    <article data-pagefind-body>
      <div class="crumb">
        <a href="/">registry</a><span class="sep">/</span>{domain}
      </div>

      <header class="head">
        <div class="favicon">
          <img src={icon} width="22" height="22" alt="" loading="lazy" onerror="this.remove()" />
        </div>
        <div class="head-body">
          <h1>{domain}</h1>
          <p class="meta">
            {records.length} integration{records.length === 1 ? "" : "s"}
            {" · "}{sections.map((s) => SHORT_LABEL[s.kind]).join(" · ")}
          </p>
        </div>
      </header>

      {sections.map((s) => (
        <section id={s.kind}>
          <div class="sec-header">
            <span class="sec-label">{s.label}</span>
            <span class="sec-note">{s.items.length}</span>
          </div>
          <ul class="recs">
            {s.items.map((r) => (
              <li>
                <a class="rec" href={`/${r.kind}/${r.slug}/`}>
                  <span class="rec-name">{r.name}</span>
                  {r.description && <span class="rec-desc">{r.description.slice(0, 130)}</span>}
                  <span class="rec-meta">{metaFor(r)}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </article>
  </div>
</Base>

<style>
  .head { padding: 24px 0 0; display: flex; align-items: flex-start; gap: 16px; max-width: 760px; }
  .favicon {
    width: 40px; height: 40px;
    border: 1px solid var(--gray-100); border-radius: 8px;
    display: grid; place-items: center;
    background: var(--white); flex-shrink: 0; margin-top: 2px;
    font-weight: 600; color: var(--gray-400);
  }
  .favicon img { border-radius: 4px; }
  h1 { font-size: 28px; font-weight: 600; letter-spacing: -0.03em; line-height: 1.2; margin: 0; word-break: break-all; }
  .meta { margin: 6px 0 0; font-family: var(--font-mono); font-size: 12px; color: var(--gray-400); }

  section { margin-top: 44px; max-width: 760px; scroll-margin-top: 24px; }

  ul.recs { list-style: none; padding: 0; margin: 0; }
  ul.recs li { border-bottom: 1px solid var(--gray-100); }
  .rec {
    display: grid;
    grid-template-columns: minmax(0, max-content) 1fr max-content;
    align-items: baseline; gap: 16px;
    padding: 13px 0; text-decoration: none;
  }
  .rec-name { font-weight: 500; font-size: 14.5px; white-space: nowrap; }
  .rec:hover .rec-name { text-decoration: underline; text-underline-offset: 3px; }
  .rec-desc {
    color: var(--gray-500); font-size: 13.5px;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0;
  }
  .rec-meta {
    font-family: var(--font-mono); font-size: 12px; color: var(--gray-400);
    white-space: nowrap; text-align: right;
  }

  @media (max-width: 700px) {
    .rec { grid-template-columns: 1fr max-content; }
    .rec-desc { display: none; }
  }
</style>
