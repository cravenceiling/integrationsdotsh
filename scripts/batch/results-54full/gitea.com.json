    "summary": "Gitea exposes a REST API at `https://gitea.com/api/v1` plus an OAuth2/OpenID Connect provider on the main host; documented auth options include personal access tokens, HTTP Basic auth, SSH-based HTTP signatures, and OAuth2 app credentials.",
    "description": "Gitea is a self-hosted and hosted Git forge for source code hosting, code review, issues, packages, and related collaboration workflows. The `gitea.com` domain hosts the public service and its documentation.",
    "credentials": {
      "gitea_pat": {
        "type": "api_key",
        "label": "Personal access token",
        "generateUrl": "https://gitea.com/user/settings/applications",
        "setup": "In Gitea, open [User Settings → Applications](https://gitea.com/user/settings/applications) and use **Manage Access Tokens** to create a token. Choose the needed permission scopes; Gitea shows the token only once. The docs also note tokens can be minted via the API at `/api/v1/users/{username}/tokens` using HTTP Basic auth with your username and password.",
        "acquisition": "manual"
      },
      "gitea_basic_password": {
        "type": "basic",
        "label": "Gitea username and password",
        "generateUrl": "https://gitea.com/user/login",
        "setup": "Sign in to your Gitea account at [gitea.com login](https://gitea.com/user/login). The API docs state HTTP Basic authentication is supported, and that creating tokens via `/api/v1/users/{username}/tokens` specifically requires Basic auth with your username and password.",
        "acquisition": "manual"
      },
      "gitea_ssh_http_sig": {
        "type": "signature",
        "label": "Registered SSH key or SSH certificate for HTTP signatures",
        "generateUrl": "https://gitea.com/user/settings/keys",
        "setup": "Add an SSH public key or SSH certificate to your Gitea account in [User Settings → SSH / GPG Keys](https://gitea.com/user/settings/keys). Then sign API requests with the matching private key using the draft-cavage HTTP Signatures format; send the signature in the `Signature` header, and include `x-ssh-certificate` when using an SSH certificate.",
        "acquisition": "manual"
      },
      "gitea_oauth_app": {
        "type": "oauth2",
        "label": "OAuth2 application client credentials",
        "generateUrl": "https://gitea.com/user/settings/applications",
        "setup": "Register an OAuth2 application in Gitea from [User Settings → Applications](https://gitea.com/user/settings/applications) or, for admins, the instance application pages described in the docs. Create an app with a name and redirect URL, then copy the generated `Client ID` and `Client Secret`. Use those in the standard OAuth flow against Gitea’s OAuth endpoints; user consent is required.",
        "acquisition": "manual"
      }
    },
