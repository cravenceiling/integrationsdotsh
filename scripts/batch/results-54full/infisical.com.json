    "summary": "Infisical exposes a public REST API, a public docs MCP server, and an installable CLI.",
    "description": "Infisical is a secrets and identity security platform for developers and machines. It provides secret management, machine identities, certificates, and related access controls for cloud and self-hosted deployments.",
    "credentials": {
      "machine_access_token": {
        "type": "bearer",
        "label": "Machine identity access token",
        "generateUrl": "https://infisical.com/docs/documentation/platform/identities/universal-auth",
        "setup": "Create a machine identity in Infisical, then configure an auth method for it. The easiest path documented is [Universal Auth](https://infisical.com/docs/documentation/platform/identities/universal-auth): go to Organization Settings → Access Control → Identities, create the identity, keep the issued `Client ID` and `Client Secret`, and exchange them at `/api/v1/auth/universal-auth/login` for a short-lived access token. Infisical also documents [Token Auth](https://infisical.com/docs/documentation/platform/identities/token-auth), where you create an access token directly on the identity and use that token against the API.",
        "acquisition": "manual"
      },
      "service_token": {
        "type": "bearer",
        "label": "Service token",
        "generateUrl": "https://infisical.com/docs/documentation/platform/token",
        "setup": "In Infisical, open [Service Token](https://infisical.com/docs/documentation/platform/token) management at Access Control → Service Tokens and click **Create token**. Configure the token scopes, permissions, and optional expiration, then copy the created token. The docs note service tokens are prefixed with `st`, and when authenticating to the API you send only the access-token portion before the last `.` delimiter.",
        "acquisition": "manual"
      },
      "oauth_client": {
        "type": "oauth2",
        "label": "OAuth application client credentials",
        "generateUrl": "https://infisical.com/docs/documentation/platform/oauth-applications",
        "setup": "To let an external platform obtain delegated access to Infisical, register an OAuth application in [OAuth Applications](https://infisical.com/docs/documentation/platform/oauth-applications): go to Organization Settings → OAuth Applications, click **Add OAuth application**, enter the redirect URIs, and save the shown `Client ID` and `Client Secret`. Infisical acts as the OAuth 2.0 authorization server under `/api/v1/oauth`; use the standard authorization-code flow from your app.",
        "acquisition": "manual"
      }
    },
