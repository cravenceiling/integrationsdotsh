    "summary": "Temporal exposes a Cloud Ops HTTP API, two CLIs (`temporal` and `tcld`), and documents a community MCP server; authentication is via Temporal Cloud API keys, interactive OAuth login stored in CLI profiles, or mTLS certificates for namespace access.",
    "description": "Temporal is a durable execution platform for building reliable applications and orchestrating long-running workflows. It offers open-source workflow infrastructure and a managed Temporal Cloud service for running and administering workflows.",
    "credentials": {
      "cloud_api_key": {
        "type": "api_key",
        "label": "Temporal Cloud API key",
        "generateUrl": "https://docs.temporal.io/cloud/api-keys",
        "setup": "In Temporal Cloud, create an API key from the Cloud UI or with [`tcld apikey create`](https://docs.temporal.io/cloud/tcld/apikey). The key is managed from the [Manage API keys](https://docs.temporal.io/cloud/api-keys) guide; copy the secret when it is created because the CLI docs note you won't be able to retrieve it again.",
        "acquisition": "manual"
      },
      "cloud_oauth_login": {
        "type": "oauth2",
        "label": "Temporal Cloud interactive login token",
        "generateUrl": "https://docs.temporal.io/cli/cloud",
        "setup": "Install the Temporal Cloud CLI extension as documented in [Install and configure the CLI](https://docs.temporal.io/cli/setup-cli), then run `temporal cloud login --profile <name>` as described in [Use with Temporal Cloud](https://docs.temporal.io/cli/cloud). This opens a browser, authenticates with Temporal Cloud, and stores the OAuth token in your selected CLI profile/TOML config. The standalone `tcld` CLI also supports browser login via [`tcld login`](https://docs.temporal.io/cloud/tcld/login).",
        "acquisition": "manual"
      },
      "cloud_mtls_cert": {
        "type": "compound",
        "label": "Temporal Cloud mTLS client certificate and private key",
        "generateUrl": "https://docs.temporal.io/cloud/certificates",
        "setup": "Configure mTLS for your Temporal Cloud Namespace following [Authenticate with mTLS certificates](https://docs.temporal.io/cloud/certificates). You must upload/manage the Namespace CA configuration in Temporal Cloud, then generate or obtain a client certificate and matching private key that meet Temporal's X.509 requirements. Use the resulting cert/key files with CLI flags like `--tls-cert-path` and `--tls-key-path`, or the equivalent SDK/client configuration.",
        "acquisition": "manual"
      }
