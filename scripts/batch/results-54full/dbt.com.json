        "generateUrl": "https://docs.getdbt.com/docs/dbt-apis/user-tokens",
        "setup": "In dbt, open **Account Settings** → **API tokens** → **Personal tokens**, click **Create personal access token**, give it a name, save it, and copy the value before closing the window. See [Personal access tokens](https://docs.getdbt.com/docs/dbt-apis/user-tokens)."
      },
      "dbt_service_token": {
        "type": "bearer",
        "label": "dbt service account token",
        "generateUrl": "https://docs.getdbt.com/docs/dbt-apis/service-tokens",
        "setup": "In dbt, an account admin with a Developer license opens **Account settings** → **Service Tokens** → **+ New Token**, assigns the needed permission sets, and copies the token when created. See [Service account tokens](https://docs.getdbt.com/docs/dbt-apis/service-tokens)."
      },
