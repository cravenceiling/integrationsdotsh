      },
      "service_account_token": {
        "type": "bearer",
        "label": "1Password service account token",
        "generateUrl": "https://start.1password.com/developer-tools/infrastructure-secrets/serviceaccount/?source=dev-portal",
        "setup": "Create a service account in [1Password Service Accounts setup](https://www.1password.dev/service-accounts/get-started): either use the [service account creation wizard](https://start.1password.com/developer-tools/infrastructure-secrets/serviceaccount/?source=dev-portal) after [signing in](https://start.1password.com/signin), or run [`op service-account create`](https://www.1password.dev/cli/reference/management-commands/service-account#service-account-create). Save the token immediately; the docs say it is shown only once.",
        "acquisition": "manual"
      },
      "connect_token": {
        "type": "bearer",
        "label": "1Password Connect server access token",
        "generateUrl": "https://start.1password.com/developer-tools/infrastructure-secrets/connect",
        "setup": "Create a Connect server workflow from the [Connect setup guide](https://www.1password.dev/connect/get-started): after [signing in](https://start.1password.com/signin), use the [Secrets Automation workflow creation wizard](https://start.1password.com/developer-tools/infrastructure-secrets/connect) or run [`op connect server create`](https://www.1password.dev/cli/reference/management-commands/connect#connect-server-create). The workflow issues an access token for authenticating to the Connect REST API, and you can create additional tokens later with [`op connect token create`](https://www.1password.dev/cli/reference/management-commands/connect#connect-token-create).",
        "acquisition": "manual"
