---
import Base from "~/layouts/Base.astro";
import { all, byKind } from "~/lib/data.ts";

const counts = {
  total: all.length,
  mcp: byKind.mcp.length,
  openapi: byKind.openapi.length,
  graphql: byKind.graphql.length,
  cli: byKind.cli.length,
};
---

<Base title="integrations.sh — every integration, in every format agents speak" path="/">
  <div class="container">
    <section class="hero">
      <p class="eyebrow">registry · MCP servers · OpenAPI · GraphQL</p>
      <h1>Every integration, in every format agents speak.</h1>
      <p class="sub" id="lede">
        {counts.total.toLocaleString()} publicly-accessible integration specs across
        MCP, OpenAPI, and GraphQL — grouped by domain, readable by you and your agent.
      </p>
      <div class="search-row">
        <input
          id="q" type="search"
          placeholder="Search integrations…"
          autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
        />
        <kbd>/</kbd>
      </div>
      <nav class="kinds" id="kinds">
        <button class="active" data-kind="">All</button>
        <button data-kind="mcp">MCP <span>{counts.mcp.toLocaleString()}</span></button>
        <button data-kind="openapi">API <span>{counts.openapi.toLocaleString()}</span></button>
        <button data-kind="graphql">GraphQL <span>{counts.graphql.toLocaleString()}</span></button>
        <button data-kind="cli">CLI <span>{counts.cli.toLocaleString()}</span></button>
      </nav>
    </section>

    <table class="rows">
      <tbody id="tbody"></tbody>
    </table>
    <div id="sentinel" aria-hidden="true"></div>
    <p class="status" id="status"></p>
  </div>
</Base>

<script>
  const PAGE = 80;
  const tbody = document.getElementById("tbody");
  const q = document.getElementById("q");
  const status = document.getElementById("status");
  const sentinel = document.getElementById("sentinel");
  const kindsNav = document.getElementById("kinds");

  const TLABEL = { mcp: "MCP", openapi: "API", graphql: "GraphQL", cli: "CLI" };
  const TORDER = ["mcp", "openapi", "graphql", "cli"];

  let records = [];
  let filtered = [];    // domain groups
  let shown = 0;
  let kind = "";
  let term = "";

  const params = new URLSearchParams(location.search);
  kind = params.get("kind") ?? "";
  term = params.get("q") ?? "";
  if (term) q.value = term;
  for (const b of kindsNav.querySelectorAll("button")) {
    b.classList.toggle("active", (b.dataset.kind ?? "") === kind);
  }

  const esc = (s) =>
    String(s).replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]));
  const fav = (d) => `https://www.google.com/s2/favicons?domain=${encodeURIComponent(d)}&sz=64`;
  const dpath = (d) => `/d/${encodeURIComponent(d)}/`;

  const buildGroups = (recs) => {
    const map = new Map();
    for (const r of recs) {
      const d = r.domain || r.slug;
      let g = map.get(d);
      if (!g) { g = { domain: d, icon: r.icon, pop: 0, total: 0, types: {} }; map.set(d, g); }
      const c = g.types[r.kind] ?? (g.types[r.kind] = { count: 0, kind: r.kind });
      c.count++;
      g.total++;
      g.pop = Math.max(g.pop, r.popularity ?? 0);
      if (!g.icon) g.icon = r.icon;
    }
    return [...map.values()].sort((a, b) =>
      b.pop - a.pop || b.total - a.total || a.domain.localeCompare(b.domain));
  };

  const groupRowHtml = (g) => {
    const icon = `<img class="c-fav" src="${esc(g.icon || fav(g.domain))}" alt="" loading="lazy" width="18" height="18" onerror="this.src='${fav(g.domain)}'">`;
    const chips = TORDER.filter((t) => g.types[t]).map((t) => {
      const c = g.types[t];
      return `<a class="chip" href="${dpath(g.domain)}#${t}">${TLABEL[t]}${c.count > 1 ? `<span class="n">${c.count}</span>` : ""}</a>`;
    }).join("");
    return `<tr>
      <td class="c-icon">${icon}</td>
      <td class="c-name"><a href="${dpath(g.domain)}">${esc(g.domain)}</a></td>
      <td class="c-chips">${chips}</td></tr>`;
  };

  const render = (reset) => {
    if (reset) { tbody.innerHTML = ""; shown = 0; }
    const next = filtered.slice(shown, shown + PAGE);
    tbody.insertAdjacentHTML("beforeend", next.map(groupRowHtml).join(""));
    shown += next.length;
    status.textContent = filtered.length
      ? `${filtered.length.toLocaleString()} domain${filtered.length === 1 ? "" : "s"}`
      : "No matches.";
  };

  const io = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting && shown < filtered.length) render(false);
  }, { rootMargin: "700px" });
  io.observe(sentinel);

  const matchRecord = (r, t) =>
    r.name.toLowerCase().includes(t) || (r.domain ?? "").includes(t) || r.slug.includes(t) || (r.description ?? "").toLowerCase().includes(t);

  const apply = () => {
    const t = term.trim().toLowerCase();
    let pool = records;
    if (kind) pool = pool.filter((r) => r.kind === kind);
    if (t) pool = pool.filter((r) => matchRecord(r, t));
    filtered = buildGroups(pool);

    const u = new URL(location.href);
    kind ? u.searchParams.set("kind", kind) : u.searchParams.delete("kind");
    term.trim() ? u.searchParams.set("q", term.trim()) : u.searchParams.delete("q");
    history.replaceState(null, "", u);
    render(true);
  };

  fetch("/api.json")
    .then((r) => r.json())
    .then((rows) => { records = rows; apply(); });

  let to = 0;
  q.addEventListener("input", () => { term = q.value; clearTimeout(to); to = setTimeout(apply, 90); });
  kindsNav.addEventListener("click", (e) => {
    const btn = e.target.closest("button");
    if (!btn) return;
    kind = btn.dataset.kind ?? "";
    for (const b of kindsNav.querySelectorAll("button")) b.classList.toggle("active", b === btn);
    apply();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "/" && document.activeElement !== q) { e.preventDefault(); q.focus(); }
  });
</script>

<style>
  .hero { padding: 64px 0 8px; max-width: 660px; }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--gray-400);
    margin: 0 0 16px;
  }
  h1 { font-size: 36px; font-weight: 600; letter-spacing: -0.04em; line-height: 1.15; margin: 0 0 14px; }
  .sub { color: var(--gray-500); font-size: 15.5px; line-height: 1.6; margin: 0 0 28px; }

  .search-row { position: relative; max-width: 480px; }
  #q {
    width: 100%;
    padding: 11px 44px 11px 14px;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: 8px;
    color: var(--gray-1000);
    font: inherit; font-size: 14px;
    outline: none;
    transition: border-color 0.12s;
  }
  #q:focus { border-color: var(--gray-400); }
  #q::placeholder { color: var(--gray-300); }
  .search-row kbd {
    position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
    font-family: var(--font-mono); font-size: 11px; color: var(--gray-300);
    border: 1px solid var(--gray-100); border-radius: 4px; padding: 1px 7px;
  }

  .kinds { display: flex; gap: 20px; padding: 20px 0 0; }
  .kinds button {
    background: none; border: 0; padding: 4px 0;
    font-family: var(--font-mono); font-size: 12.5px;
    color: var(--gray-400); cursor: pointer;
    border-bottom: 1px solid transparent;
  }
  .kinds button:hover { color: var(--gray-700); }
  .kinds button.active { color: var(--gray-1000); border-bottom-color: var(--gray-1000); }
  .kinds button span { opacity: 0.5; margin-left: 4px; }

  table.rows { width: 100%; border-collapse: collapse; margin-top: 18px; }
  :global(table.rows tbody tr) { border-bottom: 1px solid var(--gray-100); }
  :global(table.rows td) { padding: 13px 20px 13px 0; vertical-align: middle; }
  :global(.c-icon) { width: 30px; padding-right: 12px; }
  :global(.c-fav), :global(.c-icon .ph) {
    width: 18px; height: 18px; border-radius: 4px; display: block; object-fit: contain;
  }
  :global(.c-icon .ph) {
    background: var(--gray-50); border: 1px solid var(--gray-100);
    font-size: 10px; font-weight: 600; color: var(--gray-400);
    display: grid; place-items: center;
  }
  :global(.c-name) { white-space: nowrap; }
  :global(.c-name a) { font-weight: 500; font-size: 14.5px; text-decoration: none; }
  :global(table.rows tr:hover .c-name a) { text-decoration: underline; text-underline-offset: 3px; }

  :global(.c-chips) { text-align: right; white-space: nowrap; padding-right: 0 !important; }
  :global(.c-chips .chip) {
    display: inline-flex; align-items: center; gap: 5px;
    font-family: var(--font-mono); font-size: 12px;
    color: var(--gray-500);
    border: 1px solid var(--gray-100); background: var(--gray-25);
    border-radius: 5px; padding: 3px 9px; margin-left: 8px;
    text-decoration: none;
  }
  :global(.c-chips .chip:hover) { color: var(--gray-1000); border-color: var(--gray-300); }
  :global(.c-chips .chip .n) { opacity: 0.5; }

  .status { color: var(--gray-400); font-family: var(--font-mono); font-size: 12px; margin: 16px 0 0; }
  #sentinel { height: 1px; }
</style>
