---
import Base from "~/layouts/Base.astro";
import { byKind } from "~/lib/data.ts";
import { domainCount, formatsOf, listDomains } from "~/lib/catalog.ts";

const PAGE = 80;
const initial = listDomains({ limit: PAGE }); // first page, server-rendered (crawlable)
const total = domainCount();
const counts = {
  mcp: byKind.mcp.length,
  openapi: byKind.openapi.length,
  graphql: byKind.graphql.length,
  cli: byKind.cli.length,
};
const TLABEL: Record<string, string> = { mcp: "MCP", openapi: "API", graphql: "GraphQL", cli: "CLI" };
const mono = (d: string) => (d[0] || "?").toUpperCase();
---

<Base title="integrations.sh — every integration, in every format agents speak" path="/">
  <div class="container">
    <section class="hero">
      <h1>Every integration, in every format agents speak.</h1>
      <p class="sub" id="lede">
        {(counts.mcp + counts.openapi + counts.graphql + counts.cli).toLocaleString()} publicly-accessible
        integration specs across MCP, OpenAPI, and GraphQL — grouped by domain, readable by you and your agent.
      </p>
      <div class="search-row">
        <input
          id="q" type="search"
          placeholder="Search integrations…"
          autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
          autofocus
        />
        <kbd>/</kbd>
      </div>
      <a class="connect" href="/integrations.sh/">Connect your agent <span aria-hidden="true">→</span></a>
      <nav class="kinds" id="kinds">
        <button class="active" data-kind="">All</button>
        <button data-kind="mcp">MCP <span>{counts.mcp.toLocaleString()}</span></button>
        <button data-kind="openapi">API <span>{counts.openapi.toLocaleString()}</span></button>
        <button data-kind="graphql">GraphQL <span>{counts.graphql.toLocaleString()}</span></button>
        <button data-kind="cli">CLI <span>{counts.cli.toLocaleString()}</span></button>
      </nav>
    </section>

    <table class="rows">
      <tbody id="tbody">
        {initial.map((g) => (
          <tr>
            <td class="c-icon">
              {g.icon
                ? <img class="c-fav" src={g.icon} alt="" loading="lazy" width="18" height="18" onerror={`this.outerHTML='<span class="ph">${mono(g.domain)}</span>'`} />
                : <span class="ph">{mono(g.domain)}</span>}
            </td>
            <td class="c-name"><a href={`/${encodeURIComponent(g.domain)}/`}>{g.domain}</a></td>
            <td class="c-chips">
              {formatsOf(g).map((k) => (
                <a class="chip" href={`/${encodeURIComponent(g.domain)}/#${k}`}>{TLABEL[k]}{(g.formats[k] ?? 0) > 1 && <span class="n">{g.formats[k]}</span>}</a>
              ))}
            </td>
          </tr>
        ))}
      </tbody>
      <!-- Whatever you typed, if it isn't already a domain — click to open it
           (un-cataloged domains land on the 404/discover page). tfoot always
           renders below the paginated tbody. -->
      <tfoot id="typeahead" hidden></tfoot>
    </table>
    <div id="sentinel" aria-hidden="true"></div>
    <p class="status" id="status">{total.toLocaleString()} domains</p>
  </div>
</Base>

<script>
  // Progressive enhancement over the server-rendered first page: live search,
  // kind filter, and infinite scroll — all over /api/domains.json (the same
  // query layer the page rendered from).
  interface DomainRow {
    domain: string;
    icon: string | null;
    formats: Record<string, number>;
    description: string;
  }

  const PAGE = 80;
  const tbody = document.getElementById("tbody")!;
  const q = document.getElementById("q") as HTMLInputElement;
  const status = document.getElementById("status")!;
  const sentinel = document.getElementById("sentinel")!;
  const kindsNav = document.getElementById("kinds")!;
  const typeahead = document.getElementById("typeahead")!;

  const TLABEL: Record<string, string> = { mcp: "MCP", openapi: "API", graphql: "GraphQL", cli: "CLI" };
  const TORDER = ["mcp", "openapi", "graphql", "cli"];

  let all: DomainRow[] = [];
  let filtered: DomainRow[] = [];
  let shown = PAGE; // first PAGE rows are server-rendered
  let kind = "";
  let term = "";

  const params = new URLSearchParams(location.search);
  kind = params.get("kind") ?? "";
  term = params.get("q") ?? "";
  if (term) q.value = term;
  for (const b of kindsNav.querySelectorAll("button"))
    b.classList.toggle("active", (b.dataset.kind ?? "") === kind);

  const esc = (s: unknown) =>
    String(s).replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[c]!);
  const dpath = (d: string) => `/${encodeURIComponent(d)}/`;
  const isDomain = (s: string) => /^([a-z0-9-]+\.)+[a-z]{2,}$/i.test(s);
  // A pasted URL becomes a domain search: scheme, path, port, and www. fall
  // away ("https://www.mintlify.com/docs" → "mintlify.com"). Non-URLs pass through.
  const normalizeQuery = (s: string) => {
    const t = s.trim();
    if (!/^https?:\/\//i.test(t) && !/^www\./i.test(t)) return s;
    try {
      return new URL(/^https?:\/\//i.test(t) ? t : `https://${t}`).hostname.replace(/^www\./i, "");
    } catch {
      return s;
    }
  };

  const rowHtml = (g: DomainRow) => {
    const L = esc((g.domain[0] || "?").toUpperCase());
    const icon = g.icon
      ? `<img class="c-fav" src="${esc(g.icon)}" alt="" loading="lazy" width="18" height="18" onerror="this.outerHTML='<span class=&quot;ph&quot;>${L}</span>'">`
      : `<span class="ph">${L}</span>`;
    const chips = TORDER.filter((t) => g.formats[t]).map((t) =>
      `<a class="chip" href="${dpath(g.domain)}#${t}">${TLABEL[t]}${g.formats[t] > 1 ? `<span class="n">${g.formats[t]}</span>` : ""}</a>`).join("");
    return `<tr><td class="c-icon">${icon}</td><td class="c-name"><a href="${dpath(g.domain)}">${esc(g.domain)}</a></td><td class="c-chips">${chips}</td></tr>`;
  };

  // The "go to what you typed" rows — shown whenever the term isn't already a
  // known domain. Clicking opens /{domain}/ (the 404/discover page if new).
  // A full domain gets one row; a bare name ("mintlify") fans out across
  // common TLDs. Lives in tfoot, so it stays pinned below the paginated tbody
  // — always the bottom of the list, no matter how many rows are rendered.
  const TA_TLDS = ["com", "io", "dev", "ai", "co", "sh", "org", "net", "app"];
  const taRow = (d: string) => {
    const L = esc((d[0] || "?").toUpperCase());
    return `<tr class="ta-row"><td class="c-icon"><span class="ph">${L}</span></td>` +
      `<td class="c-name"><a href="${dpath(d)}">${esc(d)}</a></td>` +
      `<td class="c-chips"><span class="ta-go">discover →</span></td></tr>`;
  };
  const updateTypeahead = () => {
    const t = term.trim().toLowerCase();
    const known = new Set(all.map((g) => g.domain.toLowerCase()));
    let candidates: string[] = [];
    if (t && isDomain(t)) candidates = [t];
    else if (/^[a-z0-9-]+$/.test(t)) candidates = TA_TLDS.map((tld) => `${t}.${tld}`);
    candidates = candidates.filter((d) => !known.has(d));
    typeahead.innerHTML = candidates.map(taRow).join("");
    typeahead.hidden = candidates.length === 0;
  };

  const render = (reset: boolean) => {
    if (reset) { tbody.innerHTML = ""; shown = 0; }
    const next = filtered.slice(shown, shown + PAGE);
    tbody.insertAdjacentHTML("beforeend", next.map(rowHtml).join(""));
    shown += next.length;
    if (filtered.length) {
      status.textContent = `${filtered.length.toLocaleString()} domain${filtered.length === 1 ? "" : "s"}`;
    } else {
      // The typeahead rows below offer /{domain}/ candidates to discover —
      // unless the term can't become a domain (multi-word, symbols).
      status.textContent = typeahead.hidden ? "No matches." : "Not in the registry yet — discover it below.";
    }
  };

  const io = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting && shown < filtered.length) render(false);
  }, { rootMargin: "700px" });
  io.observe(sentinel);

  const apply = () => {
    const t = term.trim().toLowerCase();
    filtered = all.filter((g) =>
      (!kind || g.formats[kind]) &&
      (!t || g.domain.toLowerCase().includes(t) || (g.description || "").toLowerCase().includes(t)));
    const u = new URL(location.href);
    kind ? u.searchParams.set("kind", kind) : u.searchParams.delete("kind");
    term.trim() ? u.searchParams.set("q", term.trim()) : u.searchParams.delete("q");
    history.replaceState(null, "", u);
    updateTypeahead(); // before render — the empty-state status reads typeahead.hidden
    render(true);
  };

  fetch("/api/domains.json").then((r) => r.json()).then((data: DomainRow[]) => {
    all = data;
    if (kind || term.trim()) apply();
    else { filtered = all; status.textContent = `${all.length.toLocaleString()} domains`; }
    updateTypeahead();
  });

  let to: ReturnType<typeof setTimeout> | undefined;
  q.addEventListener("input", () => {
    const normalized = normalizeQuery(q.value);
    if (normalized !== q.value) q.value = normalized;
    term = normalized;
    updateTypeahead();
    clearTimeout(to);
    to = setTimeout(apply, 90);
  });
  kindsNav.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest("button");
    if (!btn) return;
    kind = btn.dataset.kind ?? "";
    for (const b of kindsNav.querySelectorAll("button")) b.classList.toggle("active", b === btn);
    apply();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "/" && document.activeElement !== q) { e.preventDefault(); q.focus(); }
  });
</script>

<style>
  .hero { padding: 64px 0 8px; max-width: 660px; }
  h1 { font-size: 36px; font-weight: 600; letter-spacing: -0.04em; line-height: 1.15; margin: 0 0 14px; }
  .sub { color: var(--gray-500); font-size: 15.5px; line-height: 1.6; margin: 0 0 28px; }

  .search-row { position: relative; max-width: 480px; }
  #q {
    width: 100%;
    padding: 11px 44px 11px 14px;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: 8px;
    color: var(--gray-1000);
    font: inherit; font-size: 14px;
    outline: none;
    transition: border-color 0.12s;
  }
  #q:focus { border-color: var(--gray-400); }
  #q::placeholder { color: var(--gray-300); }
  .search-row kbd {
    position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
    font-family: var(--font-mono); font-size: 11px; color: var(--gray-300);
    border: 1px solid var(--gray-100); border-radius: 4px; padding: 1px 7px;
  }

  .connect {
    display: inline-flex; align-items: center; gap: 6px;
    margin-top: 12px;
    font-family: var(--font-mono); font-size: 12.5px;
    color: var(--gray-400); text-decoration: none;
  }
  .connect:hover { color: var(--gray-1000); }
  .connect span { transition: transform 0.12s; }
  .connect:hover span { transform: translateX(2px); }

  .kinds { display: flex; gap: 20px; padding: 20px 0 0; }
  .kinds button {
    background: none; border: 0; padding: 4px 0;
    font-family: var(--font-mono); font-size: 12.5px;
    color: var(--gray-400); cursor: pointer;
    border-bottom: 1px solid transparent;
  }
  .kinds button:hover { color: var(--gray-700); }
  .kinds button.active { color: var(--gray-1000); border-bottom-color: var(--gray-1000); }
  .kinds button span { opacity: 0.5; margin-left: 4px; }

  table.rows { width: 100%; border-collapse: collapse; margin-top: 18px; }
  :global(table.rows tbody tr) { border-bottom: 1px solid var(--gray-100); }
  :global(table.rows td) { padding: 13px 20px 13px 0; vertical-align: middle; }
  :global(.c-icon) { width: 30px; padding-right: 12px; }
  :global(.c-fav), :global(.c-icon .ph) {
    width: 18px; height: 18px; border-radius: 4px; display: block; object-fit: contain;
  }
  :global(.c-icon .ph) {
    background: var(--gray-50); border: 1px solid var(--gray-100);
    font-size: 10px; font-weight: 600; color: var(--gray-400);
    display: grid; place-items: center;
  }
  :global(.c-name) { white-space: nowrap; }
  :global(.c-name a) { font-weight: 500; font-size: 14.5px; text-decoration: none; }
  :global(table.rows tr:hover .c-name a) { text-decoration: underline; text-underline-offset: 3px; }

  :global(.c-chips) { text-align: right; white-space: nowrap; padding-right: 0 !important; }
  :global(.c-chips .chip) {
    display: inline-flex; align-items: center; gap: 5px;
    font-family: var(--font-mono); font-size: 12px;
    color: var(--gray-500);
    border: 1px solid var(--gray-100); background: var(--gray-25);
    border-radius: 5px; padding: 3px 9px; margin-left: 8px;
    text-decoration: none;
  }
  :global(.c-chips .chip:hover) { color: var(--gray-1000); border-color: var(--gray-300); }
  :global(.c-chips .chip .n) { opacity: 0.5; }

  /* "go to what you typed" rows (cells set via JS → :global) */
  :global(table.rows tfoot[hidden]) { display: none; }
  :global(table.rows tfoot td) { border-top: 1px solid var(--gray-100); }
  :global(.ta-go) { font-family: var(--font-mono); font-size: 12px; color: var(--gray-400); }

  .status { color: var(--gray-400); font-family: var(--font-mono); font-size: 12px; margin: 16px 0 0; }
  #sentinel { height: 1px; }
</style>
