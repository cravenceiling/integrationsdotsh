    "summary": "Mapped Canva’s developer surface: 3 authenticated HTTP APIs (Connect, Admin, SCIM), 2 MCP servers (public local Dev MCP via CLI and authenticated remote Canva MCP), and 1 authenticated CLI.",
    "credentials": {
      "connect_oauth_app": {
        "type": "oauth2",
        "label": "Canva Connect integration OAuth client",
        "generateUrl": "https://www.canva.com/developers/integrations",
        "setup": "In the [Developer Portal](https://www.canva.com/developers/), open [Your integrations](https://www.canva.com/developers/integrations), click **Create an integration**, choose **Public** or **Private**, then on **Configure your integration** copy the `Client ID`, click **Generate secret** to create the `Client secret`, select the scopes you need, and add at least one authorized redirect URL under **Authentication**. Canva Connect uses OAuth 2.0 Authorization Code with PKCE; direct users to `https://www.canva.com/api/oauth/authorize` and exchange the code at `https://api.canva.com/auth/v1/oauth/token`. Your Canva account must have MFA enabled before you can create an integration."
      },
      "admin_api_client": {
        "type": "oauth2_cc",
        "label": "Canva Admin API client credentials",
        "generateUrl": "https://www.canva.com/settings/your-account",
        "setup": "In Canva, go to [Account settings](https://www.canva.com/settings/your-account), under **Organization settings** open **Admin API**, click **Create an API client**, choose the scopes, then save the `client ID` and `client secret` when Canva shows them. Use them to obtain an OAuth 2.0 Client Credentials access token for the Admin API. You must be an organization admin, belong to a Canva organization, and have SSO or MFA enabled."
      },
      "scim_bearer_token": {
        "type": "bearer",
        "label": "Canva SCIM access token",
        "generateUrl": "https://www.canva.com/settings/your-account",
        "setup": "Log in to Canva, open [Account settings](https://www.canva.com/settings/your-account), then under your team settings go to **SSO & provisioning**. Under **SCIM**, enable **SCIM user provisioning** and copy the generated access token. Canva keeps only one active SCIM token per team; toggling the setting revokes the current token and creates a new one. This is available to team administrators and owners of eligible Canva teams."
      },
      "cli_local_token": {
        "type": "bearer",
        "label": "Canva CLI local auth token",
        "generateUrl": "https://www.canva.dev/docs/apps/canva-cli/",
        "setup": "Install [@canva/cli](https://www.npmjs.com/package/@canva/cli), then run `canva login`. Approve access in the browser, copy the confirmation code back into the CLI, and the CLI stores an encrypted auth token locally in `~/.canva-cli/credentials` (or `%USERPROFILE%\\\\.canva-cli\\\\credentials` on Windows). Run `canva logout` to revoke and delete it."
      },
      "mcp_user_oauth": {
        "type": "oauth2",
        "label": "Canva MCP user OAuth authorization",
        "generateUrl": "https://www.canva.dev/docs/mcp/",
        "setup": "Configure your AI assistant to connect to the remote MCP server at `https://mcp.canva.com/mcp`. Once access is enabled and your redirect URI is allowlisted via Canva's [MCP waitlist form](https://docs.google.com/forms/d/1jgC4vAA2-5LqaNzVhnP8ygSknF4Vysc1UzAWJukzcp0/viewform), each user signs in to Canva and approves access when prompted by the MCP client. Canva recommends Client ID Metadata Documents (CIMD); Dynamic Client Registration is still available for backward compatibility. The MCP authorization server metadata is published from `https://mcp.canva.com/.well-known/oauth-authorization-server`."
      }
    },
