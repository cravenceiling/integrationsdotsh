      "booking_connect_machine_account": {
        "type": "compound",
        "label": "Connectivity machine account",
        "generateUrl": "https://connect.booking.com/machine-account",
        "setup": "Go to the [Connectivity Portal machine-account page](https://connect.booking.com/machine-account) and create or manage a machine account for your property/tenant. Save the `Client ID` and `Client Secret` shown at creation time. For token-based auth, use those to mint short-lived JWT access tokens; for legacy access, the same machine account credentials can be used directly with HTTP Basic auth until that scheme sunsets on 31 Dec 2025. If you do not have portal access, ask a colleague with existing access to create one for you from the Provider Portal."
      },
      "booking_dataportability_oauth": {
        "type": "oauth2",
        "label": "Data Portability OAuth access",
        "generateUrl": "https://developers.booking.com/datasecurity/registration",
        "setup": "Register via the [Data Portability API registration form](https://developers.booking.com/datasecurity/registration) and complete the onboarding steps, including domain verification and any requested documents. After approval, obtain user consent with the Booking.com DMA scope for either `https://account.booking.com/scope/dma` (single access) or `https://account.booking.com/scope/dma_continuous` (continuous access). Use the returned access token to call the user-provided portability URL; for continuous access, also store the refresh token securely."
      }
    },
