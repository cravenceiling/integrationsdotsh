        "type": "oauth2_cc",
        "label": "Oyster Developer Application (Client ID + Client Secret)",
        "generateUrl": "https://app.oysterhr.com/developer",
        "setup": "Create a Developer Application in Oyster. For partners, follow the [partner guide](https://docs.oysterhr.com/docs/partner-guide-to-creating-and-authorizing-a-developer-application.md); for customers, follow the [customer guide](https://docs.oysterhr.com/docs/customer-guide-to-creating-and-authorizing-a-developer-application.md). Save the app’s `client_id` and `client_secret` shown after creation. These are used to mint OAuth access tokens at `POST https://api.oysterhr.com/oauth2/token` (or the sandbox token URL when testing).",
        "acquisition": "manual"
      },
      "oyster_oauth_access_token": {
        "type": "bearer",
        "label": "Oyster OAuth access token",
        "generateUrl": "https://api.oysterhr.com/oauth2/token",
        "setup": "Mint this by exchanging your Developer Application credentials at `POST https://api.oysterhr.com/oauth2/token` for production, or `POST https://api-sandbox.oysterhr.com/oauth2/token` in the sandbox. OAuth grants supported are `authorization_code` and `client_credentials`. The returned `access_token` is a Bearer token and expires after 2 hours.",
        "acquisition": "manual"
      },
      "oyster_webhook_shared_secret": {
        "type": "bearer",
        "label": "Oyster webhook shared secret",
